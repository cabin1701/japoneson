---
// Hero for project hub pages (smaller than main Hero)
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  image: string;
  align?: 'left' | 'center';
  height?: number; // px
  fit?: 'cover' | 'contain'; // 'cover' = crop to fill, 'contain' = show full image
}
const { kicker, title, subtitle, image, align = 'left', height = 560, fit = 'cover' } = Astro.props;
---

<section class="p-hero" data-align={align} data-fit={fit} style={`background-image: url('${image}'); min-height: ${height}px;`}>
  <div class="overlay"></div>
  <div class="p-hero-content">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1 class="p-hero-title">{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .p-hero {
    width: 100%;
    background-size: cover;
    background-position: center;
    background-color: #000;
    background-repeat: no-repeat;
    position: relative;
    color: #fff;
    display: flex;
    align-items: center;
  }
  .p-hero[data-fit="contain"] {
    background-size: contain;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.35) 100%);
  }
  .p-hero-content {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    width: 100%;
  }
  .p-hero[data-align="center"] .p-hero-content { text-align: center; }

  .kicker {
    font-family: var(--font-display-cinzel);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-bg);
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .p-hero-title {
    font-family: var(--font-display-serif);
    font-weight: 900;
    font-size: 64px;
    color: var(--color-accent);
    margin: 0 0 1.2rem;
    line-height: 1.05;
    letter-spacing: 0.01em;
  }
  .subtitle {
    font-family: var(--font-display-cinzel);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-bg);
    letter-spacing: 0.05em;
    margin: 0;
    max-width: 720px;
  }
  .p-hero[data-align="center"] .subtitle { margin: 0 auto; }

  @media (max-width: 720px) {
    .p-hero { min-height: 420px !important; }
    .p-hero-title { font-size: 42px; }
    .kicker { font-size: 15px; }
    .subtitle { font-size: 17px; }
  }
</style>
