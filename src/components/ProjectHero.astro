---
// Hero for project hub pages (smaller than main Hero)
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  image?: string;
  align?: 'left' | 'center';
  height?: number; // px
  fit?: 'cover' | 'contain'; // 'cover' = crop to fill, 'contain' = show full image
  titleFont?: string; // CSS font-family value, e.g. '"Cinzel", serif'
  titleWeight?: number | string; // CSS font-weight
  titleItalic?: boolean;
  titleSize?: string; // CSS font-size override
  titleColor?: string; // CSS color override
  videoId?: string; // YouTube video ID for muted background video
  videoStart?: number; // start time in seconds
  overlayTop?: number; // overlay opacity at top (0..1)
  overlayBottom?: number; // overlay opacity at bottom (0..1)
  slideshow?: string[]; // background slideshow images (cross-fade)
  slideshowDuration?: number; // ms per slide (default 5000)
}
const {
  kicker,
  title,
  subtitle,
  image,
  align = 'left',
  height = 560,
  fit = 'cover',
  titleFont,
  titleWeight,
  titleItalic,
  titleSize,
  titleColor,
  videoId,
  videoStart,
  overlayTop = 0,
  overlayBottom = 0,
  slideshow,
  slideshowDuration = 5000,
} = Astro.props;

const hasSlideshow = Array.isArray(slideshow) && slideshow.length > 0;

const videoSrc = videoId
  ? `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&showinfo=0&modestbranding=1&playsinline=1&rel=0${videoStart ? `&start=${videoStart}` : ''}`
  : '';

const titleStyle = [
  titleFont ? `font-family: ${titleFont};` : '',
  titleWeight ? `font-weight: ${titleWeight};` : '',
  titleItalic ? 'font-style: italic;' : '',
  titleSize ? `font-size: ${titleSize};` : '',
  titleColor ? `color: ${titleColor};` : '',
].join(' ');
---

<section class="p-hero" data-align={align} data-fit={fit} style={`${image ? `background-image: url('${image}');` : ''} min-height: ${height}px;`}>
  {hasSlideshow && (
    <div class="slideshow-bg" data-duration={slideshowDuration} aria-hidden="true">
      {slideshow!.map((src, i) => (
        <div class="slide" style={`background-image: url('${src}'); opacity: ${i === 0 ? 1 : 0};`}></div>
      ))}
    </div>
  )}
  {videoId && (
    <div class="video-bg" aria-hidden="true">
      <iframe
        src={videoSrc}
        title=""
        frameborder="0"
        allow="autoplay; encrypted-media"
        allowfullscreen
      ></iframe>
    </div>
  )}
  <div class="overlay" style={`background: linear-gradient(180deg, rgba(0,0,0,${overlayTop}) 0%, rgba(0,0,0,${overlayBottom}) 100%);`}></div>
  <div class="p-hero-content">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1 class="p-hero-title" style={titleStyle}>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .p-hero {
    width: 100%;
    background-size: cover;
    background-position: center;
    background-color: #000;
    background-repeat: no-repeat;
    position: relative;
    color: #fff;
    display: flex;
    align-items: center;
  }
  .p-hero[data-fit="contain"] {
    background-size: contain;
  }
  .video-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .slideshow-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .slideshow-bg .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: opacity 500ms ease-in-out;
  }
  .video-bg iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.78vh;
    min-width: 100%;
    height: 56.25vw;
    min-height: 100%;
    transform: translate(-50%, -50%);
    border: 0;
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.35) 100%);
  }
  .p-hero-content {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 4rem 1.5rem;
    width: 100%;
  }
  .p-hero[data-align="center"] .p-hero-content { text-align: center; }

  .kicker {
    font-family: var(--font-display-cinzel);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-bg);
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .p-hero-title {
    font-family: var(--font-display-ysabeau);
    font-weight: 700;
    font-size: 64px;
    color: var(--color-accent);
    margin: 0 0 1.2rem;
    line-height: 1.05;
    letter-spacing: 0.01em;
  }
  .subtitle {
    font-family: var(--font-display-cinzel);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-bg);
    letter-spacing: 0.05em;
    margin: 0;
    max-width: 720px;
  }
  .p-hero[data-align="center"] .subtitle { margin: 0 auto; }

  @media (max-width: 720px) {
    .p-hero { min-height: 420px !important; }
    .p-hero-title { font-size: 42px; }
    .kicker { font-size: 15px; }
    .subtitle { font-size: 17px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.slideshow-bg').forEach((box) => {
    const slides = box.querySelectorAll<HTMLElement>('.slide');
    if (slides.length < 2) return;
    const dur = Number(box.dataset.duration) || 5000;
    let i = 0;
    setInterval(() => {
      slides[i].style.opacity = '0';
      i = (i + 1) % slides.length;
      slides[i].style.opacity = '1';
    }, dur);
  });
</script>
