---
// Reusable sub-projects grid for project hub pages
// (mirrors ProjectsGrid but takes cards via props)
export type SubCard = {
  title: string;
  subtitle?: string;
  image: string;
  imageAlt: string;
  taglineBold?: string;
  description?: string;
  href: string;
};
interface Props {
  cards: SubCard[];
  columns?: 2 | 3 | 4;
}
const { cards, columns = 3 } = Astro.props;
const base = import.meta.env.BASE_URL;
function resolveHref(href: string): string {
  if (href.startsWith('http')) return href;
  return base.replace(/\/$/, '') + href;
}
---

<section class="sub-projects" data-cols={columns}>
  <div class="grid">
    {cards.map((c) => (
      <a class="card" href={resolveHref(c.href)}>
        <div class="card-img-wrap">
          <img src={c.image} alt={c.imageAlt} loading="lazy" />
        </div>
        <div class="card-body">
          <h3 class="card-title">{c.title}</h3>
          {c.subtitle && <div class="card-subtitle">{c.subtitle}</div>}
          {c.taglineBold && <p class="tagline">{c.taglineBold}</p>}
          {c.description && <p class="desc">{c.description}</p>}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .sub-projects {
    max-width: var(--container-max);
    margin: 2rem auto 0;
    padding: 0 1.5rem;
  }
  .grid {
    display: grid;
    gap: 2.5rem 2rem;
    margin-top: 1.5rem;
  }
  .sub-projects[data-cols="2"] .grid { grid-template-columns: repeat(2, 1fr); }
  .sub-projects[data-cols="3"] .grid { grid-template-columns: repeat(3, 1fr); }
  .sub-projects[data-cols="4"] .grid { grid-template-columns: repeat(4, 1fr); }

  @media (max-width: 900px) {
    .sub-projects .grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 600px) {
    .sub-projects .grid { grid-template-columns: 1fr !important; }
  }

  .card {
    color: var(--color-text);
    text-decoration: none;
    display: block;
  }
  .card:hover .card-title { color: var(--color-accent); }

  .card-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body { text-align: center; }
  .card-title {
    font-family: var(--font-nav);
    font-weight: 500;
    font-size: 28px;
    color: var(--color-navy);
    margin: 0 0 4px;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }
  .card-subtitle {
    font-family: var(--font-nav);
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 8px;
    font-size: 22px;
  }
  .tagline {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    margin: 12px 0 8px;
    color: #1f1f1f;
    line-height: 1.55;
    font-weight: 600;
  }
  .desc {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: #333;
    line-height: 1.55;
    margin: 8px 0 0;
    font-weight: 400;
  }
</style>
