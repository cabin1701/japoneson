---
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
const prefix = `${base}${lang}/`;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = lang === 'en' ? 'Español' : 'English';

const nav = [
  { label: 'About', slug: 'about', hasChildren: true },
  { label: 'Angels Swing', slug: 'swing', hasChildren: true },
  { label: 'JAPONÉSON', slug: 'japoneson', hasChildren: false },
  { label: 'Mystery', slug: 'mystery', hasChildren: true },
  { label: '★MURAKAMI MAMBO', slug: 'murakami', hasChildren: true },
  { label: 'Cupie Danny', slug: 'cupie', hasChildren: true },
  { label: 'BLOG', slug: 'blog-2', hasChildren: false },
];
---

<header class="site-header">
  <div class="lang-bar">
    <a href={`${base}${otherLang}/`} class="lang-link">{otherLangLabel}</a>
  </div>
  <div class="header-main">
    <a class="logo" href={prefix}>Shoko "Seina" Shiraishi</a>
    <nav aria-label="Primary">
      <ul>
        {nav.map((n) => (
          <li>
            <a href={`${prefix}${n.slug}/`}>
              {n.label}{n.hasChildren && <span class="caret"> ▾</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg);
    padding: 0;
  }
  .lang-bar {
    text-align: right;
    padding: 0.5rem 1.5rem 0;
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .lang-link {
    font-family: var(--font-nav);
    font-size: 0.95rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .lang-link:hover { color: var(--color-accent); }

  .header-main {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0.25rem 1.5rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-bottom: 1px solid rgba(200, 16, 46, 0.3);
    flex-wrap: wrap;
  }
  .logo {
    font-family: var(--font-display-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 2rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  nav a {
    font-family: var(--font-nav);
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  nav a:hover { color: var(--color-accent); }
  .caret {
    font-size: 0.8em;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .header-main { justify-content: center; }
    .logo { font-size: 1.5rem; }
    nav ul { justify-content: center; gap: 1rem; }
    nav a { font-size: 0.95rem; }
  }
</style>
