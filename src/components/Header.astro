---
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
const prefix = `${base}${lang}/`;
const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = lang === 'en' ? 'Español' : 'English';

const nav = [
  { label: 'About', slug: 'about', hasChildren: true },
  { label: 'Angels Swing', slug: 'swing', hasChildren: true },
  { label: 'JAPONÉSON', slug: 'japoneson', hasChildren: false },
  { label: 'Mystery', slug: 'mystery', hasChildren: true },
  { label: '★MURAKAMI MAMBO', slug: 'murakami', hasChildren: true },
  { label: 'Cupie Danny', slug: 'cupie', hasChildren: true },
  { label: 'BLOG', slug: 'blog-2', hasChildren: false },
];
---

<header class="site-header">
  <div class="header-inner">
    <div class="logo-row">
      <a class="logo" href={prefix}>Shoko "Seina" Shiraishi</a>
      <a class="lang-link" href={`${base}${otherLang}/`}>{otherLangLabel}</a>
    </div>
    <nav aria-label="Primary" class="primary-nav">
      <ul>
        {nav.map((n) => (
          <li>
            <a href={`${prefix}${n.slug}/`}>
              {n.label}{n.hasChildren && <span class="caret"> ▾</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg);
  }
  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem 1.5rem 0.5rem;
    border-bottom: 1px solid rgba(200, 16, 46, 0.3);
  }

  .logo-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 0.4rem;
  }
  .logo {
    font-family: var(--font-display-serif);
    font-style: normal;
    font-weight: 500;
    font-size: 1.7rem;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .lang-link {
    font-family: var(--font-display-serif);
    font-style: normal;
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .lang-link:hover { text-decoration: underline; }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .primary-nav a {
    font-family: var(--font-nav);
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .primary-nav a:hover { color: var(--color-accent); }
  .caret {
    font-size: 0.8em;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .logo { font-size: 1.5rem; }
    .lang-link { font-size: 1.05rem; }
    .primary-nav ul { justify-content: center; gap: 1rem; }
    .primary-nav a { font-size: 0.95rem; }
  }
</style>
