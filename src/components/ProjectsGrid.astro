---
import { projects } from '../data/projects';
const base = import.meta.env.BASE_URL;

function resolveHref(href: string): string {
  if (href.startsWith('http')) return href;
  // /en/foo/ → BASE_URL + en/foo/
  return base.replace(/\/$/, '') + href;
}
---

<section class="projects-section">
  <hr class="rule" />
  <h2 class="section-title">Projects</h2>
  <hr class="rule" />

  <div class="grid">
    {projects.map((p) => (
      <a
        class="card"
        href={resolveHref(p.href)}
        {...(p.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        <div class="card-img-wrap">
          <img src={p.image} alt={p.imageAlt} loading="lazy" />
        </div>
        <div class="card-body">
          <h3 class="card-title">
            {p.flag && <span class="flag">{p.flag}</span>} {p.title}
          </h3>
          {p.subtitle && <div class="card-subtitle">{p.subtitle}</div>}
          {p.taglineBold && <p class="tagline"><strong>{p.taglineBold}</strong></p>}
          <p class="desc">{p.description}</p>
          {p.external && <span class="external-tag">External website</span>}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects-section {
    max-width: var(--container-max);
    margin: 2rem auto 0;
    padding: 0 1.5rem;
  }
  .rule + .section-title { margin-top: -1.5rem; }
  .section-title + .rule { margin-top: 1rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 2rem;
    margin-top: 2.5rem;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }

  .card {
    color: var(--color-text);
    text-decoration: none;
    display: block;
  }
  .card:hover .card-title { color: var(--color-accent); }

  .card-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    text-align: center;
  }
  .card-title {
    font-family: var(--font-nav);  /* Pathway Gothic One */
    font-weight: 500;
    font-size: 28px;
    color: var(--color-navy);
    margin: 0 0 4px;
    text-transform: none;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }
  .flag { margin-right: 0.3em; }
  .card-subtitle {
    font-family: var(--font-nav);
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 8px;
    font-size: 22px;
  }
  .tagline {
    font-family: var(--font-nav);  /* Pathway Gothic One */
    font-size: 20px;
    margin: 12px 0 8px;
    color: #1f1f1f;
    line-height: 1.45;
    font-weight: 400;
    letter-spacing: 0.01em;
  }
  .desc {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: #333;
    line-height: 1.55;
    margin: 8px 0 0;
    font-weight: 400;
  }
  .external-tag {
    display: inline-block;
    margin-top: 0.6rem;
    font-family: var(--font-nav);
    font-size: 0.85rem;
    color: var(--color-accent);
  }
</style>
