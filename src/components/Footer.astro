---
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
const prefix = `${base}${lang}/`;

const t = lang === 'es'
  ? { contact: 'Contacto', privacy: 'Política de privacidad', terms: 'Términos de uso' }
  : { contact: 'Contact', privacy: 'Privacy Policy', terms: 'Terms of use' };
---

<footer class="site-footer">
  <hr class="rule" />
  <div class="container">
    <p class="footer-tagline">ONLY MUSIC IS INCAPABLE OF LYING TO ME.</p>
    <ul class="footer-nav">
      <li><a href={`${prefix}contact/`}>{t.contact}</a></li>
      <li><a href={`${prefix}privacy-policy/`}>{t.privacy}</a></li>
      <li><a href={`${prefix}terms-and-conditions/`}>{t.terms}</a></li>
    </ul>
    <p class="footer-copy">&copy; {new Date().getFullYear()} Shoko "Seina" Shiraishi</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    padding-bottom: 2rem;
  }
  .footer-nav {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-family: var(--font-nav);
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }
  .footer-nav a:hover { color: var(--color-accent); }
  .footer-tagline {
    text-align: center;
    font-family: cinzel;
    font-style: italic;
    font-weight: 500;
    font-size: 1.40rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin: 1.5rem 0 0.5rem;
  }
  .footer-copy {
    text-align: center;
    font-family: var(--font-display-serif);
    font-style: italic;
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0;
  }
</style>
