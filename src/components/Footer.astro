---
interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
const prefix = `${base}${lang}/`;
---

<footer class="site-footer">
  <div class="container">
    <ul>
      <li><a href={`${prefix}contact/`}>Contact</a></li>
      <li><a href={`${prefix}privacy-policy/`}>Privacy</a></li>
      <li><a href={`${prefix}terms-and-conditions/`}>Terms</a></li>
    </ul>
    <p>&copy; {new Date().getFullYear()} Japonéson</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #eee;
    padding: 2rem 0;
    margin-top: 4rem;
    font-size: 0.9rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem;
    display: flex;
    gap: 1rem;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }
  p {
    margin: 0;
    color: #888;
  }
</style>
