---
interface Props {
  title?: string;
  lang?: 'en' | 'es';
}
const { title = 'Japonéson', lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-text: #222;
    --color-bg: #fff;
    --color-link: #1a4480;
  }
  body {
    margin: 0;
    font-family: system-ui, -apple-system, "Helvetica Neue", sans-serif;
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.6;
  }
  a {
    color: var(--color-link);
  }
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }
</style>
