---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;

const trail = [
  { slug: 'cupie', title: 'CUPIE DANNY', path: `${base}en/cupie/` },
  { slug: 'theater', title: 'THEATER', path: `${base}en/cupie/theater/` },
];

const characters = [
  {
    name: 'Cupie Danny',
    image: `${base}images/cupie/theater-cupie.jpg`,
    desc: 'He believes he’s the ultimate reliable big brother. Lately, his heart belongs entirely to Erika-chan. Permanently naked, because a true free spirit never feels the cold!',
  },
  {
    name: 'Shoko-chan',
    image: `${base}images/cupie/theater-shoko.jpg`,
    desc: 'The adorable Hermanita (little sister) who absolutely adores her big brother. Don’t let her cuteness fool you—she is the level-headed, reliable one!',
  },
  {
    name: 'Erika-chan',
    image: `${base}images/cupie/theater-erika1.jpg`,
    desc: 'A soulful girl into yoga, Indian philosophy, temple-hopping, and reading. Spent her childhood in Brazil. She’s a bit delicate in health, but deeply resilient.',
  },
  {
    name: 'Erika-chan',
    image: `${base}images/cupie/theater-erika2.jpg`,
    desc: 'Studying? No, thanks! A cool, naughty girl who leads the boys by the nose while being the ultimate dependable ally for the girls.',
  },
];
---

<Layout title="Theater — Cupie Danny — Japonéson" lang="en">
  <Header lang="en" />
  <main>
    <ProjectHero
      title="Theater"
      subtitle="I ❤︎ Cupie Danny"
      titleFont="'Fredoka', sans-serif"
      titleWeight={500}
      titleSize="80px"
      titleColor="#facd07"
      image={`${base}images/cupie/hero_theater.jpg`}
      align="center"
      height={760}
      fit="cover"
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="en" />
    </div>

    <section class="container theater-section">
      <hr class="theater-divider" />

      <h2 class="theater-h">Characters</h2>

      <div class="character-grid">
        {characters.map((c) => (
          <figure class="character-card">
            <img src={c.image} alt={c.name} loading="lazy" />
            <figcaption>
              <h3 class="character-name">{c.name}</h3>
              <p class="character-desc">{c.desc}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <hr class="theater-divider" />

      <h2 class="theater-h">* Episode *</h2>

      <p class="theater-note">Coming soon.</p>
    </section>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .theater-section {
    padding: 3rem 1.5rem 5rem;
  }
  .theater-h {
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 48px;
    text-align: center;
    color: var(--color-navy);
    margin: 2.5rem 0 2rem;
  }
  .theater-divider {
    border: none;
    border-top: 2px dashed var(--color-accent);
    margin: 2rem auto;
    max-width: 800px;
    opacity: 0.7;
  }
  .character-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .character-card {
    margin: 0;
    text-align: center;
  }
  .character-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
  }
  .character-name {
    font-family: 'Fredoka', sans-serif;
    font-weight: 500;
    font-size: 26px;
    color: var(--color-navy);
    margin: 1rem 0 0.5rem;
  }
  .character-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 360px;
    margin: 0 auto;
  }
  .theater-note {
    text-align: center;
    color: var(--color-muted);
    font-style: italic;
  }
  @media (max-width: 640px) {
    .character-grid { grid-template-columns: 1fr; }
  }
</style>

