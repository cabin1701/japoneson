const trail = [
  { slug: 'cupie', title: 'CUPIE DANNY', path: `${base}en/cupie/` },
  { slug: 'gallery-02', title: 'FRIENDS & FAMILY', path: `${base}en/cupie/gallery-02/` },
];
---

<Layout title="Gallery — Friends & Family — Japonéson" lang="en">
  <Header lang="en" />
  <main>
    <ProjectHero
      title="Friends & Family"
      titleFont="'Fredoka', sans-serif"
      titleWeight={600}
      titleSize="70px"
      titleColor="var(--color-accent)"
      image={`${base}images/cupie/hero_gallery-02.jpg`}
      align="center"
      height={860}
      fit="cover"
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="en" />
    </div>

    <section class="gallery-wrap">
      <h2 class="sect-h">Family</h2>
      <div class="gallery-grid">
        {family.map((p) => (
          <figure class="g-card">
            <div class="g-image"><img src={p.image} alt={p.name} loading="lazy" /></div>
            <figcaption>
              <p class="g-name">{p.name}</p>
              {p.place && <p class="g-place">- {p.place} -</p>}
              {p.qpd && <p class="g-qpd">{p.qpd}</p>}
            </figcaption>
          </figure>
        ))}
      </div>

      <h2 class="sect-h">Friends</h2>
      <div class="gallery-grid">
        {friends.map((p) => (
          <figure class="g-card">
            <div class="g-image"><img src={p.image} alt={p.name} loading="lazy" /></div>
            <figcaption>
              <p class="g-name">{p.name}</p>
              {p.place && <p class="g-place">- {p.place} -</p>}
              {p.qpd && <p class="g-qpd">{p.qpd}</p>}
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .gallery-wrap {
    padding: 3rem 1.5rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .sect-h {
    font-family: 'Cherry Swash', cursive;
    font-weight: 700;
    font-size: 32px;
    color: var(--color-accent);
    text-align: center;
    margin: 2.5rem 0 2rem;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem 2rem;
  }
  .g-card {
    margin: 0;
    text-align: center;
  }
  .g-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
  }
  .g-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .g-name {
    font-family: 'Cherry Swash', cursive;
    font-weight: 400;
    font-size: 19px;
    color: var(--color-navy);
    margin: 0.8rem 0 0.2rem;
    line-height: 1.25;
  }
  .g-place {
    font-family: 'Cherry Swash', cursive;
    font-weight: 400;
    font-size: 16px;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.25;
  }
  .g-qpd {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 13px;
    color: #888;
    margin: 0.5rem 0 0;
  }

  @media (max-width: 1000px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
