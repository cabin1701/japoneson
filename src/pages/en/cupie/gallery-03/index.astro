const trail = [
  { slug: 'cupie', title: 'CUPIE DANNY', path: `${base}en/cupie/` },
  { slug: 'gallery-03', title: 'ADVENTURE', path: `${base}en/cupie/gallery-03/` },
];
---

<Layout title="Gallery — Adventure — Japonéson" lang="en">
  <Header lang="en" />
  <main>
    <ProjectHero
      title="Adventure"
      titleFont="'Fredoka', sans-serif"
      titleWeight={600}
      titleSize="70px"
      titleColor="var(--color-accent)"
      image={`${base}images/cupie/hero_gallery-03.jpg`}
      align="center"
      height={860}
      fit="cover"
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="en" />
    </div>

    <section class="gallery-wrap">
      <div class="gallery-grid">
        {photos.map((p) => (
          <figure class="g-card">
            <img src={IMG(p)} alt="" loading="lazy" />
          </figure>
        ))}
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .gallery-wrap {
    padding: 3rem 1.5rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .g-card {
    margin: 0;
  }
  .g-card img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  @media (max-width: 1000px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
