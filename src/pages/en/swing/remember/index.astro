---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';
const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `https://en.japoneson.com/wp-content/uploads/${p}`;

const contents = [
  { label: 'Introduction', href: `${base}en/swing/remember/preface/` },
  { label: 'TIMELINE: war and events around Kitakyushu City', href: `${base}en/swing/remember/preface/#timeline` },
  { label: 'KOKURA: Army Arsenal', href: `${base}en/swing/remember/kokura/` },
  { label: 'MOJI: Departure, Air Raids, and Allied POWs', href: `${base}en/swing/remember/moji/` },
  { label: 'The Great Yawata Air Raid (Aug 8, 1945)', href: `${base}en/swing/remember/yahata/` },
  { label: 'The Atomic Bomb over Kokura: August 9, 1945', href: `${base}en/swing/remember/atomicbomb/` },
  { label: 'KOKURA MEMORIAL CROSS | For Fallen Soldiers of the Korean War', href: `${base}en/swing/remember/memorial_cross/` },
  { label: 'MOJI: World Peace Pagoda', href: `${base}en/swing/remember/pagoda/` },
  { label: 'The friendship between Dutch ex-POWs and Mizumaki Town', href: `${base}en/swing/remember/mizumaki/` },
  { label: 'Towards the Future / Seina', href: `${base}en/swing/remember/future/` },
];

const trail = [
  { slug: 'swing', title: 'ANGELS SWING', path: `${base}en/swing/` },
  { slug: 'remember', title: 'WE REMEMBER YOU', path: `${base}en/swing/remember/` },
];
---

<Layout title='We Remember You — Wartime and Postwar Kitakyushu — Japonéson' lang="en">
  <Header lang="en" />
  <main>
    <ProjectHero
      kicker="Wartime and Postwar Kitakyushu"
      title="We Remember You"
      subtitle="A booklet for the 50th anniversary of the merger of Moji, Kokura, Tobata, Yawata, and Wakamatsu — 2013."
      image={IMG('2026/05/kitakyushuu.jpg')}
      image="/japoneson/images/swing/hero_memorial.jpg"
      align="center"
      height={900}
      fit="cover"
      titleFont='"Cormorant Infant", serif'
      titleWeight={700}
      titleItalic={true}
      titleColor="#ff1b06"
      titleSize="85px"
    />
    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="en" />
    </div>

    <section class="essay">
      <div class="essay-inner">
       
        <h2>Towards the Future:</h2>
        

        <div class="cover-image">
          <img src={IMG('2026/05/kitakyushuu-768x768.jpg')} alt="Kitakyushu — We Remember You" loading="lazy" />
        </div>

        <p>
          In 1963, the five cities of Moji, Kokura, Tobata, Yawata, and Wakamatsu merged to form Kitakyushu City. This booklet was published in 2013 to mark the 50th anniversary of that merger.
        </p>
        <p>
          Through my project "<a href={`${base}en/swing/dream/`}>I Have a Dream… Seina</a>", I encountered a U.S. Marine veteran who had been captured in the Philippines during WWII. He was brought to Moji Port and forced to work as a prisoner of war in a coal mine in Fukuoka Prefecture.
        </p>
        <p>
          Moji is my hometown. It was from this elderly American man that I learned the hidden pieces of the history of the city where I was born and raised.
        </p>
        <p>
          This booklet documents not only the stories of Allied prisoners of war but also the broader history of Kitakyushu before and after the Pacific War. It is a tribute to those who lost their lives in my hometown and to the soldiers who departed from our shores for the battlefields of South Asia, never to return.
        </p>
        <p>
          This is my message to the future: we must never forget this history.
        </p>
      </div>
    </section>

    <section class="contents">
      <div class="contents-inner">
        <h3 class="contents-title">Contents</h3>
        <ul>
          {contents.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="essay">
      <div class="essay-inner">
        <hr class="rule" />
        <p class="photo-credit">
          Photography cooperation: Kazumichi Kidera (<a href="https://www.fuweb.co.jp/" target="_blank" rel="noopener noreferrer">FU. photo & design</a>)
        </p>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .breadcrumb-wrap {
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .essay {
    padding: 2rem 1.5rem 3rem;
  }
  .essay-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .essay-inner h2 {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 24px;
    color: var(--color-accent);
    margin: 1.2rem 0 0.5rem;
    text-align: center;
  }
  .essay-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.2rem;
  }
  .essay-inner a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .contents {
    padding: 1rem 1.5rem 2rem;
  }
  .contents-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .contents-title {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 22px;
    color: var(--color-accent);
    text-align: center;
    margin: 1rem 0 1.5rem;
    letter-spacing: 0.05em;
  }
  .contents ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(208, 0, 0, 0.15);
  }
  .contents li {
    border-bottom: 1px solid rgba(208, 0, 0, 0.15);
  }
  .contents a {
    display: block;
    padding: 0.9rem 0.5rem;
    font-family: var(--font-display-cinzel);
    font-size: 17px;
    color: var(--color-navy);
    text-decoration: none;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }
  .contents a:hover {
    color: var(--color-accent);
    background: rgba(208, 0, 0, 0.04);
  }

  .cover-image {
    margin: 2rem auto;
    max-width: 480px;
  }
  .cover-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rule {
    border: 0;
    border-top: 1px solid rgba(208, 0, 0, 0.2);
    margin: 2rem 0 1.5rem;
  }
  .photo-credit {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    color: var(--color-muted);
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 720px) {
    .essay-inner h2 { font-size: 20px; }
  }
</style>
