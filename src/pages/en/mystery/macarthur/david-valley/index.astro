---
import Layout from '../../../../../layouts/Layout.astro';
import Header from '../../../../../components/Header.astro';
import Footer from '../../../../../components/Footer.astro';
import Breadcrumb from '../../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

interface Row {
  year: string;
  heading: string;
  body: string;
}

const rows: Row[] = [
  {
    year: '1950 – Early 1951',
    heading: 'From the Frozen Battlefields',
    body: "As a member of the U.S. Army's 24th Infantry Division, David was sent to the front lines of the brutal Korean War. Surviving extreme conditions and the loss of many comrades, he carried with him a profound sense of having been “spared” for a reason.",
  },
  {
    year: 'April 1951',
    heading: 'Joining General MacArthur',
    body: "He returned to Japan escorting the General following his relief of command. In a dramatic shift from the hell of the battlefield, he took on the prestigious role of an Honor Guard in Tokyo. He stood by the General's side at a definitive moment when the gears of history were turning.",
  },
  {
    year: 'April 1951 – March 1952',
    heading: 'A Deep Love for Japan',
    body: 'Even after the General departed for America, David remained in Japan to complete his service. During this time, he witnessed the strength and kindness of the Japanese people as they rebuilt their nation. This year in Japan became a silent prelude to his meeting with Seina decades later.',
  },
  {
    year: '2000s – 2013',
    heading: 'The Guardian of Fading Memories',
    body: 'As his fellow guardsmen passed away one by one, David stepped forward as a leader. Serving as the Executive Director and the Last Chairman of the General MacArthur Honor Guard Association (GMHGA), he dedicated his life to preserving historical records and the legacy of his comrades.',
  },
  {
    year: 'December 2012',
    heading: 'An Email Across the Ocean',
    body: 'A message arrived from Seina, who was researching the Memorial Cross (the 24th ID monument) in Kokura. David was deeply moved by the passion of this Japanese woman who sought to uncover the “roots” of his own past.',
  },
  {
    year: 'May 12, 2013',
    heading: '"The Shadows are Lengthening"',
    body: "Quoting MacArthur's famous words—“The shadows are lengthening for me”—David wrote his final letter to the members, announcing the closing of the Association. Having fulfilled his duty as the Last Chairman, he stood as a lone veteran, ready for the next chapter.",
  },
  {
    year: 'Late May 2013',
    heading: 'The Meeting in San Diego',
    body: 'Only weeks after closing the Association, on Memorial Day, David finally met Seina in San Diego. Seeing the same “truth-seeking soul” in her eyes that he and his comrades once shared, he affectionately called her “Maverick” and entrusted her with the invisible baton of history.',
  },
];

const trail = [
  { slug: 'mystery', title: 'THE MYSTERY ENTERTAINMENT', path: `${base}en/mystery/` },
  { slug: 'macarthur', title: "THE GENERAL'S SHADOW", path: `${base}en/mystery/macarthur/` },
  { slug: 'david-valley', title: 'DAVID VALLEY', path: `${base}en/mystery/macarthur/david-valley/` },
];
---

<Layout title="David Valley — Japonéson" lang="en">
  <Header lang="en" />
  <main>
    <ProjectHero
      title="David Valley"
      subtitle="The MacArthur's Honor Guard"
      titleFont="var(--font-display-cinzel)"
      titleWeight={600}
      titleSize="60px"
      titleColor="#acbdc9"
      image={`${base}images/mystery/hero_david-valley.jpg`}
      align="center"
      height={860}
      fit="cover"
      overlayTop={0}
      overlayBottom={0}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="en" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p>
          My encounter with David Valley began when I was researching the "Memorial Cross" in Kokura, Kitakyushu. I went to the local ward office, but I couldn't find any convincing answer as to why a Korean War memorial was standing there. Even the stories from local people didn't feel right to me. So, I started visiting old bookstores, searching for memories of Kokura during the Occupation.
        </p>

        <p>
          There, I found a fragile, old book that looked like it would crumble at any moment. It contained records of the U.S. Army's 24th Infantry Division stationed in Kokura and their commander, General Dean, who was deeply loved by the local citizens. I thought, "The 24th Infantry Division... maybe their veterans' association can tell me something."
        </p>

        <p>
          With that simple thought, I sent an email. That was the moment the gears of fate began to turn. I received an immediate reply from Tom Seal, the webmaster, followed shortly by a message on my website's contact form from David Valley. He said he was an "Honor Guard" for General MacArthur. At the time, I didn't even know such an organization existed.
        </p>

        <p class="across-eras">
          Across eras, ages, countries, and backgrounds, we met as if guided by something invisible. It wasn't until 13 years later that I realized I had been entrusted with a "Key to History" that no one in Japan knew about. Here, I will introduce David—the man who holds the heart of this "Mystery Entertainment"—his background, and who he was as a key figure in this story.
        </p>

        <hr class="olive-divider" />

        <div class="dv-table">
          <div class="dv-row dv-header">
            <div class="dv-year">Year</div>
            <div class="dv-events">Events</div>
          </div>
          {rows.map((r, i) => (
            <div class:list={['dv-row', i % 2 === 0 ? 'is-shade' : 'is-plain']}>
              <div class="dv-year"><strong>{r.year}</strong></div>
              <div class="dv-events">
                <p class="dv-heading"><strong>{r.heading}</strong></p>
                <p class="dv-body">{r.body}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="dv-photos">
          <figure><img src={IMG('2026/03/IMG_2041-600x450.jpg')} alt="Seina, Mrs. Valley, and David Valley in San Diego, Memorial Day 2013" loading="lazy" /></figure>
          <figure><img src={`${base}images/mystery/IMG_2050.jpg`} alt="ADOPTED ARMY DAUGHTER cap signed by David Valley" loading="lazy" /></figure>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 4rem;
  }
  .intro-inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .intro-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.3rem;
  }
  .intro-inner strong { font-weight: 700; color: #1a1a1a; }
  .intro-inner em { font-style: italic; }

  .intro-inner p.across-eras {
    font-family: 'Gabriela', serif;
    font-size: 19px;
    line-height: 1.75;
    color: var(--color-navy);
    font-style: italic;
    margin: 2rem 0;
  }

  .intro-inner hr.olive-divider {
    border: none;
    border-top: 6px solid #8a8b6a;
    margin: 2.5rem 0;
    opacity: 0.8;
  }

  .dv-table {
    width: 100%;
    margin: 2rem 0;
    border: 1px solid #c8c8c8;
  }
  .dv-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    border-bottom: 1px solid #c8c8c8;
  }
  .dv-row:last-child { border-bottom: none; }
  .dv-row.dv-header {
    background: transparent;
  }
  .dv-row.is-shade {
    background: rgba(33, 50, 101, 0.04);
  }
  .dv-year {
    padding: 1.2rem 1rem;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: #2a2a2a;
    border-right: 1px solid #c8c8c8;
  }
  .dv-events {
    padding: 1.2rem 1.2rem;
  }
  .dv-row.dv-header .dv-year,
  .dv-row.dv-header .dv-events {
    font-weight: 700;
    color: #1a1a1a;
  }
  .dv-heading {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    color: #1a1a1a;
    margin: 0 0 0.6rem !important;
  }
  .dv-body {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: #2a2a2a;
    margin: 0 !important;
  }

  .dv-photos {
    margin: 2.5rem 0 0;
    display: grid;
    grid-template-columns: 63fr 37fr;
    gap: 2rem;
    align-items: start;
  }
  .dv-photos figure { margin: 0; }
  .dv-photos img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }
  @media (max-width: 700px) {
    .dv-photos { grid-template-columns: 1fr; }
  }

  @media (max-width: 700px) {
    .dv-row { grid-template-columns: 1fr; }
    .dv-year { border-right: none; border-bottom: 1px solid #c8c8c8; }
  }
</style>
