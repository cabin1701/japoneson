---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import EssaySidebar from '../../../components/EssaySidebar.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('essay', ({ data }) => data.lang === 'es' && !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, i) => ({
    params: { slug: post.id.replace(/^(en|es)\//, '') },
    props: {
      post,
      newer: posts[i - 1] || null,
      older: posts[i + 1] || null,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}/${d.getFullYear()}`;

const slugOf = (id: string) => id.replace(/^(en|es)\//, '');
const essayBase = `${base}es/essay/`;
const HERO_FALLBACK = `${base}images/essay/swing_cut.jpg`;
---

<Layout title={`${post.data.title} – JAPONÉSON`} lang="es">
  <Header lang="es" />

  {post.data.hero ? (
    <section
      class="post-hero"
      aria-label={post.data.title}
      style={`background-image: url('${base}${post.data.hero}');`}
    ></section>
  ) : (
    <section
      class="essay-hero"
      aria-label="P.S. I Love You"
      style={`background-image: url('${HERO_FALLBACK}');`}
    >
      <div class="essay-hero-inner">
        <h1 class="essay-hero-title">P.S. I Love You</h1>
        <p class="essay-hero-sub">Dear, I thought I'd drop a line....</p>
      </div>
    </section>
  )}

  <header class="post-header-plain">
    <h1 class="post-title-plain">{post.data.title}</h1>
    <p class="post-meta-plain">
      <span>{post.data.author ?? 'Seina'}</span>
      <span class="sep">•</span>
      <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmtDate(post.data.date)}</time>
    </p>
  </header>

  <div class="post-shell">
    <article class="post">
      <div class="post-body">
        <Content />
      </div>

      {post.data.category && post.data.category.length > 0 && (
        <div class="post-meta-row" aria-label="Category">
          <span class="post-meta-label">Category</span>
          <ul>
            {post.data.category.map((c, idx) => {
              const href = idx === 0
                ? `${essayBase}?cat=${encodeURIComponent(c)}`
                : `${essayBase}?cat=${encodeURIComponent(post.data.category[0])}%2F${encodeURIComponent(c)}`;
              return <li><a class="post-cat" href={href}>{c}</a></li>;
            })}
          </ul>
        </div>
      )}

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-meta-row" aria-label="Tags">
          <span class="post-meta-label">Tags</span>
          <ul>
            {post.data.tags.map((t) => (
              <li><a class="post-tag" href={`${essayBase}?q=${encodeURIComponent(t)}`}>{t}</a></li>
            ))}
          </ul>
        </div>
      )}

      <nav class="post-nav" aria-label="Post navigation">
        {older ? (
          <a class="post-nav-link prev" href={`${essayBase}${slugOf(older.id)}/`}>
            <span class="post-nav-arrow">←</span>
            <span class="post-nav-label">Older</span>
            <span class="post-nav-title">{older.data.title}</span>
          </a>
        ) : <span></span>}
        {newer ? (
          <a class="post-nav-link next" href={`${essayBase}${slugOf(newer.id)}/`}>
            <span class="post-nav-label">Newer</span>
            <span class="post-nav-title">{newer.data.title}</span>
            <span class="post-nav-arrow">→</span>
          </a>
        ) : <span></span>}
      </nav>
    </article>

    <EssaySidebar lang="es" currentId={post.id} />
  </div>

  <Footer lang="es" />
</Layout>

<style>
  .post-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 55vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    margin-top: 1rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .post-hero::after { display: none; }
  .post-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1.5rem 2.5rem;
    max-width: 900px;
  }
  .post-hero-title {
    margin: 0 0 0.75rem;
    font-family: 'Pathway Gothic One', sans-serif;
    font-weight: 600;
    font-size: 3.2rem;
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #fff;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }
  .post-hero-meta {
    margin: 0;
    font-family: 'Helvetica', sans-serif;
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.92);
  }
  .post-hero-meta .sep {
    margin: 0 0.5rem;
    color: var(--color-accent);
    font-style: normal;
  }

  .essay-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 60vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
  }
  .essay-hero::after { display: none; }
  .essay-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1.5rem;
  }
  .essay-hero-title {
    margin: 0;
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 4rem;
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--color-accent);
    text-shadow: 0 2px 14px rgba(255, 255, 255, 0.5);
  }
  .essay-hero-sub {
    margin: 0.85rem 0 0;
    font-family: 'Cormorant Infant', serif;
    font-style: italic;
    font-weight: 500;
    font-size: 1.35rem;
    color: var(--color-navy);
    letter-spacing: 0.02em;
  }

  .post-header-plain {
    max-width: 1100px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
    text-align: left;
  }
  .post-title-plain {
    color: var(--color-accent);
    font-family: 'Pathway Gothic One', sans-serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1.1;
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
  }
  .post-meta-plain {
    margin: 0;
    font-family: 'Cormorant Infant', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .post-meta-plain .sep {
    margin: 0 0.5rem;
    color: var(--color-accent);
    font-style: normal;
  }

  .post-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: minmax(0, 760px) 260px;
    gap: 3.5rem;
    justify-content: center;
  }

  .post { min-width: 0; }

  .post-body {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text);
  }
  .post-body :global(p) { margin: 0 0 1.25rem; }
  .post-body :global(h2) {
    font-family: 'Cinzel', serif;
    font-size: 1.7rem;
    color: var(--color-accent);
    margin: 2.5rem 0 1rem;
    letter-spacing: 0.02em;
  }
  .post-body :global(h3) {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: var(--color-navy);
    margin: 2rem 0 0.75rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-family: 'Cormorant Infant', serif;
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-navy);
  }
  .post-body :global(strong) { color: var(--color-navy); }
  .post-body :global(em) { color: var(--color-accent); font-style: italic; }
  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
  .post-body :global(hr) {
    border: 0;
    border-top: 1px solid rgba(208, 0, 0, 0.25);
    margin: 2.5rem auto;
    max-width: 12rem;
  }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .post-body :global(li) { margin-bottom: 0.5rem; }
  .post-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 2rem auto;
  }

  .post-meta-row {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(208, 0, 0, 0.18);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }
  .post-meta-row:first-of-type { margin-top: 3rem; }
  .post-meta-label {
    font-family: 'Marcellus SC', serif;
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    min-width: 5rem;
  }
  .post-meta-row ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .post-cat {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    font-family: 'Pathway Gothic One', sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    background: transparent;
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .post-cat:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .post-tag {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    font-family: 'Helvetica', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    background: rgba(33, 50, 101, 0.04);
    border: 1px solid rgba(33, 50, 101, 0.2);
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .post-tag:hover {
    background: rgba(33, 50, 101, 0.1);
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(208, 0, 0, 0.25);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--color-text);
    padding: 0.75rem 0;
  }
  .post-nav-link.next { text-align: right; }
  .post-nav-arrow {
    font-family: 'Helvetica', sans-serif;
    font-size: 1.1rem;
    color: var(--color-accent);
  }
  .post-nav-label {
    font-family: 'Helvetica', sans-serif;
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .post-nav-title {
    font-family: 'Pathway Gothic One', sans-serif;
    font-size: 1.1rem;
    line-height: 1.25;
    color: var(--color-navy);
    transition: color 0.2s ease;
  }
  .post-nav-link:hover .post-nav-title {
    color: var(--color-accent);
  }

  @media (max-width: 960px) {
    .post-shell { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .essay-hero-title { font-size: 2.4rem; }
    .essay-hero-sub { font-size: 1rem; }
    .post-hero-title { font-size: 1.9rem; }
    .post-title-plain { font-size: 1.7rem; }
    .post-body { font-size: 1rem; }
    .post-nav { grid-template-columns: 1fr; gap: 1.5rem; }
    .post-nav-link.next { text-align: left; }
  }
</style>
