---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;

type LangBlock = { code: string; label: string; titles: string[] };

const langs: LangBlock[] = [
  {
    code: 'en', label: 'Inglés',
    titles: [
      'Almost Transparent Blue',
      'Coin Locker Babies',
      'Sixty-Nine',
      'Popular Hits of the Showa Era',
      'Piercing',
      'Audition',
      'In the Miso Soup',
      'From the Fatherland with Love',
      'Tokyo Decadence: 15 Stories',
    ],
  },
  {
    code: 'es', label: 'Español',
    titles: ['Azul casi transparente', 'Los chicos de las taquillas', 'Sopa de miso'],
  },
  {
    code: 'fr', label: 'Francés',
    titles: [
      'Bleu presque transparent',
      'La guerre commence au-delà de la mer',
      'Les Bébés de la consigne automatique',
      'Ecstasy',
      "Chansons populaires de l'ère Showa",
      'Kyoko',
      'Melancholia',
      'LOVE & POP',
      'Miso soup',
      'Lignes',
      'Parasites',
      'Thanatos',
      'Topaze',
    ],
  },
  {
    code: 'it', label: 'Italiano',
    titles: ['Blu quasi trasparente', '69 Sixty-nine', 'Piercing', 'Audition', 'Tokyo Soup'],
  },
  {
    code: 'de', label: 'Alemán',
    titles: [
      'Coin Locker Babys',
      'Superhits der Shōwa-Ära',
      'Das Casting',
      'In der Misosuppe',
      'In Liebe, dein Vaterland II: Der Untergang',
      'In Liebe, Dein Vaterland I: Die Invasion',
    ],
  },
  {
    code: 'ru', label: 'Ruso',
    titles: [
      'Vse ottenki golubogo',
      '69 (Sixty-Nine)',
      'Otel "Rafflz"',
      'Ekstaz',
      'Karaoke',
      'Pirsing',
      'Melankholiya',
      'Kinoproba',
      'Miso-sup',
      'Linii',
      'Parazity',
      'Tanatos',
      'Deti iz kamery khraneniya (Los niños de la consigna automática)',
      'Vojna nachinaetsya za morem',
      'Hity epohi Seva',
      'Monologi o naslazhdenii, apatii i smerti',
    ],
  },
  {
    code: 'tr', label: 'Turco',
    titles: ['Yok Yere…', 'Şeffaf Mavi', 'Gecenin Dibi'],
  },
  {
    code: 'ro', label: 'Rumano',
    titles: ['În supă miso'],
  },
  {
    code: 'el', label: 'Griego',
    titles: ['Σχεδόν διάφανο γαλάζιο'],
  },
  {
    code: 'hr', label: 'Croata',
    titles: ['U miso-juhi'],
  },
  {
    code: 'pt', label: 'Portugués',
    titles: ['Audição', 'Miso Soup'],
  },
  {
    code: 'ca', label: 'Catalán',
    titles: ['Pírcing'],
  },
  {
    code: 'nl', label: 'Neerlandés',
    titles: ['De karaokeoorlog'],
  },
];

const trail = [
  { slug: 'murakami', title: 'MURAKAMI MAMBO !!', path: `${base}es/murakami/` },
  { slug: 'books', title: "Libros de Ryu Murakami", path: `${base}es/murakami/books/` },
];
---

<Layout title="Libros de Ryu Murakami — Japonéson" lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="TRADUCIDOS EN TODO EL MUNDO"
      title="Libros de Ryu Murakami"
      subtitle="Más de 100 publicaciones desde 1976 en Japón — y las obras traducidas y publicadas en todo el mundo."
      image={`${base}images/murakami/hero_books.jpg`}
      align="center"
      height={620}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p>
          <strong>Las obras de Ryu Murakami se han publicado más de 100 veces
          desde 1976 en Japón.</strong>
        </p>
        <p>Esta es una lista de los títulos traducidos y publicados en todo el mundo.</p>
        <nav class="lang-jump" aria-label="Jump to language">
          {langs.map((l) => (
            <a href={`#${l.code}`}>{l.label}</a>
          ))}
        </nav>
      </div>
    </section>

    <section class="lists">
      <div class="lists-inner">
        {langs.map((l) => (
          <div class="lang-block" id={l.code}>
            <h2 class="lang-title">{l.label}</h2>
            <ul class="titles">
              {l.titles.map((t) => (<li>{t}</li>))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 1rem;
  }
  .intro-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .intro-inner p {
    font-family: var(--font-display-cinzel);
    font-size: 20px;
    line-height: 1.55;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .lang-jump {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem 1.1rem;
    margin: 1.5rem 0 0;
  }
  .lang-jump a {
    font-family: var(--font-nav);
    font-size: 19px;
    color: var(--color-accent);
    text-decoration: none;
  }
  .lang-jump a:hover { text-decoration: underline; }

  .lists {
    padding: 3rem 1.5rem 4rem;
  }
  .lists-inner {
    max-width: 960px;
    margin: 0 auto;
    column-count: 2;
    column-gap: 3rem;
  }
  @media (max-width: 720px) {
    .lists-inner { column-count: 1; }
  }

  .lang-block {
    break-inside: avoid;
    margin-bottom: 2.5rem;
  }
  .lang-title {
    font-family: var(--font-display-cinzel-dec);
    font-weight: 700;
    font-size: 22px;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(208, 0, 0, 0.3);
    padding-bottom: 0.4rem;
    margin: 0 0 1rem;
  }
  .titles {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .titles li {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: #2a2a2a;
    padding: 0.15rem 0;
  }
</style>
