---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

type Record = {
  image: string;
  title: string;
  artist: string;
  year: string;
  href?: string; // undefined = display only
};

const records9200: Record[] = [
  { image: IMG('2024/01/1992_nueva.jpg'),                title: 'Nueva Generación',                    artist: 'NG La Banda',                                year: '1992', href: '/es/murakami/music/nueva-generacion/' },
  { image: IMG('2024/02/1993NG.jpg'),                    title: 'Cabaret Panorámico / Échale Limón',   artist: 'NG La Banda',                                year: '1993', href: '/es/murakami/music/cabaret_panoramico/' },
  { image: IMG('2024/01/1993-live.jpg'),                 title: 'Live in Japan',                       artist: 'NG La Banda',                                year: '1993', href: '/es/murakami/music/1993_live_in-japan/' },
  { image: IMG('2024/02/1993_Paulo.jpg'),                title: 'No Hace Falta Pensar La Muerte',      artist: 'Paulo y Su Elite',                           year: '1993', href: '/es/murakami/music/1993_no-hace-falta/' },
  { image: IMG('2024/01/1993-xiomara-laugart_500.jpg'),  title: "You Don't Know What Love Is",         artist: 'Xiomara Laugart',                            year: '1993', href: '/es/murakami/music/you-dont-know-what-love-is/' },
  { image: IMG('2024/02/1994-los-vanvan.jpg'),           title: 'Los Van Van 1974',                    artist: 'Los Van Van',                                year: '1994', href: '/es/murakami/music/1994-los-van-van-1974/' },
  { image: IMG('2024/02/1995-bruja.jpg'),                title: 'La Bruja',                            artist: 'NG La Banda',                                year: '1994', href: '/es/murakami/music/1995-la-bruja/' },
  { image: IMG('2024/01/1994-jose-luis_500.jpg'),        title: '"The Man" who called "TOSCO"',        artist: 'José Luis Cortés',                           year: '1994', href: '/es/murakami/music/the-man-who-called-tosco/' },
  { image: IMG('2024/02/1995canzone.jpg'),               title: 'Cuban Canzone',                       artist: 'Estrellas de Cuba',                          year: '1995', href: '/es/murakami/music/1995-cuban-canzone/' },
  { image: IMG('2024/02/1995_NG-House.jpg'),             title: 'Cuban House Music',                   artist: 'NG La Banda',                                year: '1995', href: '/es/murakami/music/1995-cuban-house-music/' },
  { image: IMG('2024/02/1995NG-rock.jpg'),               title: 'Cuban Rock Spirit',                   artist: 'NG La Banda',                                year: '1995', href: '/es/murakami/music/1995-cuban-rock-sprit/' },
  { image: IMG('2024/01/1995-KYOKO_500.jpg'),            title: 'KYOKO Original Sound Track',          artist: 'KYOKO OST',                                  year: '1995–1996', href: '/es/murakami/music/kyoko-01/' },
  { image: IMG('2024/02/1996_javierolmo.jpg'),           title: 'Historia de un Amor',                 artist: 'Javier Olmo',                                year: '1996', href: '/es/murakami/music/1997-historia-de-un-amor/' },
  { image: IMG('2024/02/1997-los-van-van.jpg'),          title: 'Gentle & Sexy — The Best of Los Van Van', artist: 'Los Van Van',                            year: '1997', href: '/es/murakami/music/1997_gentle_and_sexy/' },
  { image: IMG('2024/02/1995_NG-best.jpg'),              title: "MURAKAMI's NG La Banda Best",         artist: 'NG La Banda',                                year: '1997', href: '/es/murakami/music/1997-ng-la-banda-best/' },
  { image: IMG('2024/02/1998_javier_sonalson.jpg'),      title: 'Son al Son',                          artist: 'Javier Olmo',                                year: '1998', href: '/es/murakami/music/son-al-son/' },
];


const records0111: Record[] = [
  { image: IMG('2024/01/2007_Di-Que-Piensas.jpg'),       title: 'Di Que Piensas',                      artist: 'Tania Pantoja',                              year: '2007' },
  { image: IMG('2024/01/2007.jpg'),                      title: 'Piano de Solar',                      artist: 'Lázaro Valdés',                              year: '2007' },
  { image: IMG('2024/01/2008_Bolero.jpg'),               title: 'BOLERO',                              artist: 'Lázaro Valdés',                              year: '2008' },
  { image: IMG('2024/01/2009_RCN.jpg'),                  title: 'RCN Salsa Best',                      artist: "Ryu's Cuban Night",                          year: '2009' },
  { image: IMG('2024/01/2009_besame.jpg'),               title: 'Bésame Mucho',                        artist: 'Tania Pantoja',                              year: '2009' },
  { image: IMG('2024/01/2010_amapola.jpg'),              title: 'AMAPOLA',                             artist: 'Tania Pantoja',                              year: '2010' },
  { image: IMG('2024/01/2011_tania_Haila.jpg'),          title: 'TANIA vs HAILA',                      artist: 'Tania Pantoja / Haila Mompié',               year: '2011' },
  { image: IMG('2024/01/2011_como-fue.jpg'),             title: 'Como Fue',                            artist: 'Tania Pantoja',                              year: '2011' },
];

const final2014: Record = {
  image: IMG('2024/01/2014_ryus-cuban.jpg'),
  title: "Ryu's Cuban Night 20th Anniversary",
  artist: 'Various Artists',
  year: '2014',
};

function resolveHref(href: string): string {
  if (href.startsWith('http')) return href;
  return base.replace(/\/$/, '') + href;
}

const trail = [
  { slug: 'murakami', title: 'MURAKAMI MAMBO !!', path: `${base}es/murakami/` },
  { slug: 'music', title: 'Música cubana — Sello MURAKAMI', path: `${base}es/murakami/music/` },
];
---

<Layout title='Música cubana — Sello MURAKAMI — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="SELLO MURAKAMI · PERÍODO ESPECIAL"
      title="Música cubana"
      subtitle="Los discos que Ryu Murakami produjo y lanzó durante el Período Especial — y después."
      image={`${base}images/murakami/hero_music.jpg`}
      align="center"
      height={900}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p class="prompt">
          En la década de 1990, durante el "Período Especial"—la época más difícil tras el colapso de la Unión Soviética—, Ryu Murakami realizó numerosas grabaciones y llenó un vacío en la historia de la música cubana.
        </p>

        <blockquote class="ryu-quote">
          <p>
            En 1991 visité Cuba por primera vez. A medida que regresaba, me di cuenta de algo. La música cubana no es solo "música folclórica" o "Salsa". Es mucho más compleja y profunda. Tiene una larga historia y diversidad, al igual que la música negra en los Estados Unidos. En aquel entonces, estaba aburrido del Rock y del Jazz, y solo escuchaba música clásica. Pero, poco a poco, me convertí en prisionero de la "magia" de la música cubana.
          </p>
          <p>
            Es imposible explicar su encanto en una sola palabra. En primer lugar, la gente de allí necesita la música. Y el nivel de los músicos es increíblemente alto. Después de la revolución, reciben una educación clásica de primer nivel en las escuelas de arte. Por ejemplo, la percusión es obligatoria. Incluso los violinistas o saxofonistas deben tocar el piano. Cuando estos músicos de alto nivel tocan, se crea una "catarsis". La mayoría de los japoneses no tienen esta experiencia, por lo que es muy difícil explicar el encanto de la música cubana. Solo puedo decir una cosa: "Por favor, vayan a ver el escenario".
          </p>
          <footer>— Ryū Murakami, <em>La vida es un carnaval</em> (Single Cut, 1996)</footer>
        </blockquote>
      </div>
    </section>

    <section class="era">
      <h2 class="era-title">1992 — 2000</h2>
      <div class="records">
        {records9200.map((r) => (
          <a class="record" href={r.href ? resolveHref(r.href) : '#'}>
            <div class="record-img"><img src={r.image} alt={r.title} loading="lazy" /></div>
            <h3 class="record-title">{r.title}</h3>
            <p class="record-meta">{r.artist}<br /><span class="year">({r.year})</span></p>
          </a>
        ))}
      </div>
    </section>

    <section class="era">
      <h2 class="era-title">2001 — 2011</h2>
      <div class="records">
        {records0111.map((r) => (
          <div class="record no-link">
            <div class="record-img"><img src={r.image} alt={r.title} loading="lazy" /></div>
            <h3 class="record-title">{r.title}</h3>
            <p class="record-meta">{r.artist}<br /><span class="year">({r.year})</span></p>
          </div>
        ))}
      </div>
    </section>

    <section class="era final">
      <h2 class="era-title">2014 · The Final</h2>
      <div class="records final-grid">
        <div class="record no-link">
          <div class="record-img"><img src={final2014.image} alt={final2014.title} loading="lazy" /></div>
          <h3 class="record-title">{final2014.title}</h3>
          <p class="record-meta">{final2014.artist}<br /><span class="year">({final2014.year})</span></p>
        </div>
      </div>
      <div class="final-quote">
        <p>
          Este año, para celebrar el vigésimo aniversario, he invitado a los miembros de principios de los 90 de "NG LA BANDA". Ellos son la razón por la que me enamoré de la música cubana. Quería recuperar ese sonido increíble. 
        </p>
        <p>
          Por supuesto, vendrá Tony Calá, el cantante más popular de su época dorada. Además, como invitados especiales, tenemos a Mayito Rivera, la voz masculina número uno de "Los Van Van", y a la famosa Tania Pantoja. 
        </p>
        <p>
          Quería que este concierto fuera algo especial que mostrara mis 20 años produciendo música cubana. Por eso he reunido a estos artistas increíbles en un mismo escenario.
        </p>
        

        <iframe width="700" height="450" src="https://www.youtube.com/embed/3q-I8rTm87A?si=Ic2uoOXv_FfDpiu8" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      <p class="sig">— Ryū Murakami</p>
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 1rem;
  }
  .intro-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .prompt {
    font-family: var(--font-display-cinzel);
    font-size: 21px;
    color: var(--color-navy);
    font-weight: 500;
    text-align: center;
    margin: 0 0 2rem;
    line-height: 1.55;
  }
  .ryu-quote {
    border-left: 3px solid var(--color-rule);
    padding: 0.5rem 0 0.5rem 1.4rem;
    margin: 0;
    font-family: var(--font-italic-quote);
    font-style: italic;
    color: #444;
  }
  .ryu-quote p {
    font-family: var(--font-italic-quote);
    font-style: italic;
    font-size: 21px;
    line-height: 1.7;
    margin: 0 0 0.9rem;
  }
  .ryu-quote footer {
    font-style: normal;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 19px;
    color: var(--color-muted);
    margin-top: 0.8rem;
  }

  .era {
    max-width: var(--container-max);
    margin: 3rem auto 0;
    padding: 0 1.5rem;
  }
  .era-title {
    font-family: var(--font-display-cinzel-dec);
    font-weight: 700;
    font-size: 28px;
    color: var(--color-accent);
    text-align: center;
    letter-spacing: 0.05em;
    margin: 0 0 1.5rem;
  }
  .records {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem 1.5rem;
  }
  @media (max-width: 900px) {
    .records { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .records { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .records { grid-template-columns: 1fr; }
  }

  .record {
    text-decoration: none;
    color: var(--color-text);
    text-align: center;
    display: block;
  }
  .record:hover .record-title { color: var(--color-accent); }
  .record.no-link { cursor: default; }

  .record-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 0.8rem;
    background: #f5f5f5;
  }
  .record-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .record-title {
    font-family: var(--font-nav);
    font-weight: 500;
    font-size: 19px;
    color: var(--color-navy);
    margin: 0 0 4px;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }
  .record-meta {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    color: #444;
    line-height: 1.4;
    margin: 0;
  }
  .year { color: var(--color-muted); font-style: italic; }

  .final-grid {
    grid-template-columns: minmax(260px, 360px) !important;
    justify-content: center;
  }
  .final-quote {
    max-width: 900px;
    margin: 2rem auto 4rem;
    padding: 0 1.5rem;
    font-family: var(--font-italic-quote);
    font-style: italic;
    color: #444;
    font-size: 21px;
    line-height: 1.7;
    text-align: center;
  }
  .final-quote p { margin: 0 0 0.9rem; }
  .final-quote .sig {
    font-style: normal;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 19px;
    color: var(--color-muted);
    margin-top: 1rem;
  }
</style>
