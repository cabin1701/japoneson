---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';
import SubGrid from '../../../../components/SubGrid.astro';
import type { SubCard } from '../../../../components/SubGrid.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

const subCards: SubCard[] = [
  {
    title: 'El nuevo otro, Cuba',
    image: IMG('2026/05/kyoko01-e1779687767424-600x600.jpg'),
    imageAlt: 'El nuevo otro, Cuba',
    description:
      '"Llegamos a conocernos a nosotros mismos a través de nuestras relaciones con los demás, y con otro nuevo otro, nuestras relaciones anteriores se vuelven objetivas." — Ryu Murakami, de "La trayectoria de KYOKO"',
    href: '/es/murakami/kyoko/newother/',
  },
  {
    title: 'El "japonés herido" que hay en mí',
    image: IMG('2026/05/IMAGE0047-e1779688101635-768x768.jpg'),
    imageAlt: 'El japonés herido que hay en mí',
    description:
      'El "japonés herido que hay en mí" era un "japonés" que, como ciudadano de un país derrotado, cargaba con un sentimiento de culpa, no podía sentirse orgulloso de su país y no podía amarlo. Un ensayo que conecta con "El nuevo otro, Cuba."',
    href: '/es/murakami/kyoko/me/',
  },
  {
    title: '"KYOKO" es la historia del propio Ryu Murakami.',
    image: IMG('2026/05/kyoko-dancin-BW-e1779687636421-768x768.jpg'),
    imageAlt: 'KYOKO bailando',
    description:
      '"Sentí que regresaba al \'espíritu\' que tenía cuando escribí Azul casi transparente." — Ryu Murakami',
    href: '/es/murakami/kyoko/boku/',
  },
];

const trail = [
  { slug: 'murakami', title: 'MURAKAMI MAMBO !!', path: `${base}es/murakami/` },
  { slug: 'kyoko', title: 'KYOKO (1995)', path: `${base}es/murakami/kyoko/` },
];
---

<Layout title='KYOKO (1995) — Because of You — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker='LA HISTORIA DE LA "ESPERANZA" Y LA "REGENERACIÓN"'
      title="KYOKO (1995)"
      subtitle="Because of You — Tokio → Nueva York → Miami → La Habana."
      image={`${base}images/murakami/hero_kyoko.jpg`}
      align="center"
      height={920}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p class="opener-quote">
          <em>"Mi único objetivo era volver a verlo, darle las gracias y bailar
          con él, oírle decir que había progresado."</em>
          <span class="speaker">— Kyoko</span>
        </p>
        <p class="stars">＊ ＊ ＊ ＊ ＊ ＊ ＊</p>
        <p class="opener-quote">
          <em>"Buena suerte, niña, todo te irá bien. Dios está contigo."</em>
          <span class="speaker">— Ralph Biggs</span>
        </p>

        <p class="prompt">
          <strong>
            Como novela es una "obra menor", pero, por decirlo a lo grande, es la obra que cambió mi vida. — Ryu Murakami
          </strong>
        </p>

        <div class="video-wrap">
          <iframe
            src="https://www.youtube.com/embed/Nl0HyMmJSh0"
            title='KYOKO (1995) trailer'
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>

        <p class="prompt">
          <strong>
            Desde Nueva York, recorrimos la costa este de los Estados Unidos
            hasta Miami y luego hasta Cuba, la "tierra de la música y la danza."
          </strong>
        </p>

        <p class="body">
          Hace doce años, José, un soldado estadounidense y bailarín, le enseñó a
          bailar a Kyoko, de 8 años, que crecía en un pueblo cercano a una base
          militar. Kyoko vuela a Estados Unidos para encontrarse con el hombre que
          le enseñó lo más importante para ella. En su viaje, que va mucho más
          allá de sus sueños más descabellados, pasa como el viento entre
          inmigrantes, exiliados, enfermos de SIDA y hombres homosexuales.
        </p>
      </div>
    </section>

    <section class="essay-section">
      <h2 class="section-h">Nueva York · Cuba · Japón</h2>
    </section>

    <SubGrid cards={subCards} columns={3} />

    <section class="outro">
      <div class="outro-inner">
        <h2 class="section-h">Because of You</h2>
        <p>Ahora estoy bien. Me di cuenta de que solo hay futuro cuando estoy en camino.</p>
        <p>
          Es inquietante e inestable mientras voy de camino a algún lugar, pero
          creo que probablemente saldrá bien.
        </p>
        <p class="closing">
          Porque el baile que José me enseñó está ahí, en mi cuerpo —<br />
          él vive en mí.
        </p>
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 2rem;
  }
  .intro-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .opener-quote {
    font-family: var(--font-italic-quote);
    font-style: italic;
    font-size: 22px;
    color: var(--color-navy);
    line-height: 1.55;
    margin: 0 0 0.8rem;
  }
  .opener-quote .speaker {
    display: block;
    font-family: Helvetica, Arial, sans-serif;
    font-style: normal;
    font-size: 14px;
    color: var(--color-muted);
    margin-top: 0.3rem;
  }
  .stars {
    text-align: center;
    color: var(--color-muted);
    letter-spacing: 0.5em;
    margin: 1.5rem 0;
    font-size: 14px;
  }
  .prompt {
    font-family: var(--font-display-cinzel);
    font-size: 19px;
    color: var(--color-text);
    margin: 2rem 0 1.5rem;
    line-height: 1.45;
  }
  .body {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    text-align: left;
    margin: 1.5rem 0 0;
  }
  .video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 1.5rem 0;
    background: #000;
  }
  .video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .essay-section {
    margin-top: 3rem;
  }
  .section-h {
    font-family: var(--font-display-cinzel-dec);
    font-weight: 700;
    font-size: 28px;
    color: var(--color-accent);
    text-align: center;
    letter-spacing: 0.05em;
    margin: 0 0 1.5rem;
  }

  .outro {
    padding: 3rem 1.5rem 4rem;
  }
  .outro-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .outro-inner p {
    font-family: var(--font-italic-quote);
    font-style: italic;
    font-size: 20px;
    color: var(--color-navy);
    line-height: 1.7;
    margin: 0 0 1rem;
  }
  .outro-inner .closing {
    font-size: 21px;
    font-weight: 400;
    color: var(--color-accent);
    margin-top: 2rem;
  }

  @media (max-width: 720px) {
    .opener-quote { font-size: 19px; }
    .prompt { font-size: 17px; }
    .section-h { font-size: 22px; }
  }
</style>
