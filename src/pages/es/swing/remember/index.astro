---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';
const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

const contents = [
  { label: 'Introducción', href: `${base}es/swing/remember/preface/` },
  { label: 'CRONOLOGÍA: guerra y eventos en torno a la ciudad de Kitakyushu', href: `${base}es/swing/remember/preface/#timeline` },
  { label: 'KOKURA: Arsenal del Ejército', href: `${base}es/swing/remember/kokura/` },
  { label: 'MOJI: Partida, bombardeos aéreos y prisioneros aliados', href: `${base}es/swing/remember/moji/` },
  { label: 'El gran bombardeo aéreo de Yahata (8 de agosto de 1945)', href: `${base}es/swing/remember/yahata/` },
  { label: 'La bomba atómica sobre Kokura: 9 de agosto de 1945', href: `${base}es/swing/remember/atomicbomb/` },
  { label: 'CRUZ CONMEMORATIVA DE KOKURA | Por los soldados caídos en la Guerra de Corea', href: `${base}es/swing/remember/memorial_cross/` },
  { label: 'MOJI: Pagoda de la Paz Mundial', href: `${base}es/swing/remember/pagoda/` },
  { label: 'La amistad entre los ex prisioneros de guerra neerlandeses y la ciudad de Mizumaki', href: `${base}es/swing/remember/mizumaki/` },
  { label: 'Hacia el futuro / Seina', href: `${base}es/swing/remember/future/` },
];

const trail = [
  { slug: 'swing', title: 'ANGELS SWING', path: `${base}es/swing/` },
  { slug: 'remember', title: 'WE REMEMBER YOU', path: `${base}es/swing/remember/` },
];
---

<Layout title='We Remember You — Wartime and Postwar Kitakyushu — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="Kitakyushu en tiempos de guerra y posguerra"
      title="We Remember You"
      subtitle="Un folleto por el 50.º aniversario de la fusión de Moji, Kokura, Tobata, Yawata y Wakamatsu — 2013."
      image={`${base}images/swing/hero_remember.jpg`}
      image="/images/swing/hero_memorial.jpg"
      align="center"
      height={900}
      fit="cover"
      titleFont='"Cormorant Infant", serif'
      titleWeight={700}
      titleItalic={true}
      titleColor="#ff1b06"
      titleSize="85px"
    />
    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="essay">
      <div class="essay-inner">

        <h2>Hacia el futuro:</h2>


        <div class="cover-image">
          <img src={IMG('2026/05/kitakyushuu-768x768.jpg')} alt="Kitakyushu — We Remember You" loading="lazy" />
        </div>

        <p>
          En 1963, las cinco ciudades de Moji, Kokura, Tobata, Yawata y Wakamatsu se fusionaron para formar la ciudad de Kitakyushu. Este folleto se publicó en 2013 para conmemorar el 50.º aniversario de esa fusión.
        </p>
        <p>
          A través de mi proyecto "<a href={`${base}es/swing/dream/`}>I Have a Dream… Seina</a>", conocí a un veterano de la Marina de EE. UU. que había sido capturado en Filipinas durante la Segunda Guerra Mundial. Fue llevado al puerto de Moji y obligado a trabajar como prisionero de guerra en una mina de carbón de la prefectura de Fukuoka.
        </p>
        <p>
          Moji es mi ciudad natal. Fue gracias a este anciano estadounidense que aprendí las partes ocultas de la historia de la ciudad donde nací y crecí.
        </p>
        <p>
          Este folleto no solo documenta las historias de los prisioneros de guerra aliados, sino también la historia más amplia de Kitakyushu antes y después de la Guerra del Pacífico. Es un tributo a quienes perdieron la vida en mi ciudad natal y a los soldados que partieron desde nuestras costas hacia los campos de batalla del sur de Asia, para no regresar jamás.
        </p>
        <p>
          Este es mi mensaje para el futuro: nunca debemos olvidar esta historia.
        </p>
      </div>
    </section>

    <section class="contents">
      <div class="contents-inner">
        <h3 class="contents-title">Índice</h3>
        <ul>
          {contents.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="essay">
      <div class="essay-inner">
        <hr class="rule" />
        <p class="photo-credit">
          Colaboración fotográfica: Kazumichi Kidera (<a href="https://www.fuweb.co.jp/" target="_blank" rel="noopener noreferrer">FU. photo & design</a>)
        </p>
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap {
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .essay {
    padding: 2rem 1.5rem 3rem;
  }
  .essay-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .essay-inner h2 {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 24px;
    color: var(--color-accent);
    margin: 1.2rem 0 0.5rem;
    text-align: center;
  }
  .essay-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.2rem;
  }
  .essay-inner a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .contents {
    padding: 1rem 1.5rem 2rem;
  }
  .contents-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .contents-title {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 22px;
    color: var(--color-accent);
    text-align: center;
    margin: 1rem 0 1.5rem;
    letter-spacing: 0.05em;
  }
  .contents ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(208, 0, 0, 0.15);
  }
  .contents li {
    border-bottom: 1px solid rgba(208, 0, 0, 0.15);
  }
  .contents a {
    display: block;
    padding: 0.9rem 0.5rem;
    font-family: var(--font-display-cinzel);
    font-size: 17px;
    color: var(--color-navy);
    text-decoration: none;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }
  .contents a:hover {
    color: var(--color-accent);
    background: rgba(208, 0, 0, 0.04);
  }

  .cover-image {
    margin: 2rem auto;
    max-width: 480px;
  }
  .cover-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rule {
    border: 0;
    border-top: 1px solid rgba(208, 0, 0, 0.2);
    margin: 2rem 0 1.5rem;
  }
  .photo-credit {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    color: var(--color-muted);
    text-align: center;
    font-style: italic;
  }

  @media (max-width: 720px) {
    .essay-inner h2 { font-size: 20px; }
  }
</style>
