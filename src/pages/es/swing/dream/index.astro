---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';
import SubGrid from '../../../../components/SubGrid.astro';
import type { SubCard } from '../../../../components/SubGrid.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

const subCards: SubCard[] = [
  {
    title: 'From Ryu Murakami',
    image: IMG('2026/05/ryu-1.jpg'),
    imageAlt: 'From Ryu Murakami',
    description: '',
    href: '/es/swing/dream/ryu/',
  },
  {
    title: 'Letters From Nursing Homes',
    image: IMG('2026/05/letters.jpg'),
    imageAlt: 'Letters From Nursing Homes',
    description: '.',
    href: '/es/swing/dream/letters/',
  },
];

const trail = [
  { slug: 'swing', title: 'ANGELS SWING', path: `${base}es/swing/` },
  { slug: 'dream', title: 'I HAVE A DREAM… SEINA', path: `${base}es/swing/dream/` },
];
---

<Layout title='I Have a Dream… Seina — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="LAS CANCIONES PARA LOS ASILOS DE ANCIANOS EN EE. UU."
      title="I Have a Dream… Seina"
      subtitle="3500 asilos de ancianos en Estados Unidos — un regalo de canciones."
      image={`${base}images/swing/hero_dream.jpg`}
      align="center"
      height={900}
      fit="cover"
      titleFont='"Cormorant Infant", serif'
      titleWeight={700}
      titleItalic={true}
      titleColor="#a6cef1"
      titleSize="85px"
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="essay">
      <div class="essay-inner">
        <h2>Todo comenzó con mis pensamientos...</h2>

        <p>
          En 1992, me encontré con un álbum titulado G.I.Jo. Había una grabación en el álbum de Jo Stafford, quien fue una de las cantantes más populares durante la Segunda Guerra Mundial.
        </p>
        <p>
          En ese álbum, ella cantaba sobre la guerra y la vida en aquella época. Mi corazón quedó cautivado por esas canciones. Desde entonces, enfoqué mi atención en la música de la era de la Segunda Guerra Mundial, y escuché muchas de esas canciones. Para una persona nacida mucho después de la guerra, era difícil comprender el sentimiento de aquella época.
        </p>
        <p>
          La música de esa era era muy hermosa, romántica y sentimental. Y la música reflejaba el sentimiento de guerra, cuando los amantes tenían que separarse y rezaban por reencontrarse. Podía sentir que no les quedaba otra opción más que rezar. A través de estas canciones, pude comprender las penas y las emociones que la gente vivió.
        </p>
        <p>
          Hay canciones que todavía son amadas y atesoradas hoy. Sin embargo, hay algunas canciones que la gente ha olvidado. Además, hay canciones que perduran hasta hoy, pero no son apreciadas por su verdadero significado y la época de la que provienen.
        </p>
        <p>
          La razón por la que esas canciones perduran hoy es probablemente por las muchas oraciones puestas en ellas.
        </p>
        <p>
          Como cantante que verdaderamente ama la música de esta era, quiero decirles que sus canciones todavía respiran y están vivas. Sé que Japón y EE. UU. estaban en guerra durante la Segunda Guerra Mundial. Pero ahora, quiero que sepan que sus canciones todavía son amadas por muchas personas en Japón.
        </p>
        <p>
          Para quienes todavía sienten dolor al recordar aquella época, me gustaría ofrecer mis canciones, con calidez, amor... y mis oraciones.
        </p>
        <hr class="navy-rule" />

        <div class="musicians">
          <p>Leonard Gaskin (contrabajo),</p>
          <p>Artie Baker (Clarinete y Saxo Tenor),</p>
          <p>Toya (piano), Grady Tate (batería),</p>
          <p>Ron Roulier (piano),</p>
          <p>Howard Kimbo (Saxo Tenor)</p>
          <p>Seina (Voz)</p>
        </div>

        <div class="video-wrap">
          <iframe
            src="https://www.youtube-nocookie.com/embed/FY-yB9-tC8U"
            title="I Have a Dream — Seina"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>

        <div class="video-wrap">
          <iframe
            src="https://www.youtube-nocookie.com/embed/3iOpyhnJ3bk"
            title="I Have a Dream — Seina (2)"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <div class="subgrid-narrow">
    <hr class="navy-rule" />
      <SubGrid cards={subCards} columns={2} />
    </div>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap {
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .subgrid-narrow {
    max-width: 50%;
    margin: 0 auto;
  }
  @media (max-width: 720px) {
    .subgrid-narrow { max-width: 100%; }
  }

  .essay {
    padding: 2rem 1.5rem 3rem;
  }
  .essay-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .essay-inner h2 {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 24px;
    color: var(--color-accent);
    margin: 1.5rem 0 0.5rem;
    text-align: center;
  }
  .essay-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.2rem;
  }

  .musicians {
    margin: 2.5rem 0;
    text-align: center;
  }
  .musicians p {
    font-family: var(--font-display-cinzel);
    font-size: 16px;
    color: var(--color-navy);
    margin: 0.3rem 0;
    line-height: 1.5;
  }

  .video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 2rem 0;
  }
  .video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 720px) {
    .essay-inner h2 { font-size: 20px; }
  }
</style>
