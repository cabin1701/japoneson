---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ProjectHero from '../../../components/ProjectHero.astro';
import SubGrid from '../../../components/SubGrid.astro';
import type { SubCard } from '../../../components/SubGrid.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

const subCards: SubCard[] = [
  {
    title: 'I Have a Dream...Seina The Songs for Nursing Homes in The U.S. 1999',
    image: IMG('2026/05/yomiuri-1024x1009.jpg'),
    imageAlt: 'I Have a Dream...Seina 1999',
    description:
      'Un proyecto de CD regalado a 3500 asilos de ancianos en todo Estados Unidos.',
    href: '/es/swing/dream/',
  },
  {
    title: 'Thanks Letters From Nursing Homes',
    image: IMG('2026/05/letters.jpg'),
    imageAlt: 'Thanks Letters From Nursing Homes',
    description:
      'Estas palabras son preciosas para mi vida. Cartas de los asilos de ancianos, incluso cuando escribí mal mi dirección de correo. Gracias por escribirme.',
    href: '/es/swing/dream/letters/',
  },
  {
    title: "I'll Be Seeing You, Leonard Gaskin 2008",
    image: IMG('2026/05/leonard.jpg'),
    imageAlt: 'Leonard Gaskin 2008',
    description:
      'Es una historia ocho años después de "I Have a Dream..Seina". Sobre visitar al Sr. Leonard Gaskin, un legendario contrabajista y su mentor.',
    href: '/es/swing/leonard-gaskin/',
  },
  {
    title: 'Thanks for the Memory 2011 Preparing...',
    image: IMG('2026/05/omote2-1024x1024.jpg'),
    imageAlt: 'Thanks for the Memory 2011',
    description:
      'Bob Cranshaw, gracias por los encuentros y los recuerdos. Este álbum se hizo realidad con recuerdos de ti.',
    href: '/es/swing/memory/',
  },
  {
    title: 'We Remember You Wartime and Postwar Kitakyushu 2013',
    image: IMG('2026/05/kitakyushuu.jpg'),
    imageAlt: 'We Remember You — Kitakyushu 2013',
    description: '',
    href: '/es/swing/remember/',
  },
  {
    title: '"For The Boys" The Korean War',
    image: IMG('2026/05/monica.jpg'),
    imageAlt: 'For The Boys — Monica Lewis',
    description:
      'En 1951, mi amiga la Sra. Monica Lewis (1922-2015) entretuvo "para los muchachos" que sirvieron en la Guerra de Corea junto a Danny Kaye.',
    href: '/es/swing/for-the-boys/',
  },
];

const trail = [
  { slug: 'swing', title: 'ANGELS SWING', path: `${base}es/swing/` },
];
---

<Layout title='Angels Swing — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="JAZZ E HISTORIA DE GUERRA"
      title="Angels Swing"
      subtitle="Para los ángeles que hicieron swing conmigo — a través de la guerra, a través de la edad, a través del océano."
      image="/images/swing/swing.jpg"
      align="center"
      height={1000}
      fit="cover"
      titleFont='"Cormorant Infant", serif'
      titleWeight={700}
      titleItalic={true}
      titleColor="#a6cef1"
      titleSize="85px"
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="essay">
      <div class="essay-inner">
        <h2>Jazz e Historia de Guerra</h2>
        <p>
          Amo las canciones populares estadounidenses de los años 1930 y 1940. Mis músicos favoritos son Glenn Miller, Frank Sinatra, Doris Day, Judy Garland, Connie Boswell, Bing Crosby, Jo Stafford, y más. Sin siquiera pensarlo, comencé a cantar esas viejas canciones populares estadounidenses en varios comedores de Nueva York donde se reúnen muchas personas mayores...
        </p>
        <p>
          "Angels Swing" comenzó en 1997, basado en mi deseo de compartir las canciones populares estadounidenses de la era de la Segunda Guerra Mundial con la gente que recordaba aquellos viejos tiempos, y de decirles que su música todavía es amada hoy, más allá de la guerra y la edad. En ese entonces, el ángel de "Angels Swing" consistía en un solo miembro, una pequeña chica asiática que no entendía muy bien el inglés.
        </p>
        <p>
          La música estadounidense, y muchos músicos que conocieron a la chica en Nueva York, le dieron muchos sueños, milagros, calidez y esperanza. El legendario músico Leonard Gaskin me trajo mucha gracia y milagros para hacer realidad mi sueño. Grady Tate me enseñó las maravillas del mundo de la música, y de la vida misma. Bob Cranshaw me brindó mucho apoyo y palabras llenas de consideración.
        </p>
        <p>
          Gracias a ellos, me encontré en una situación en la que trabajo con muchos ángeles para hacer música. Y finalmente, el "Angel's Swing" de un solo miembro se convirtió en "Angels Swing".
        </p>
        <p>
          Angels Swing es un proyecto pensado como muestra de mi gratitud hacia la vieja música estadounidense que me dio tanta alegría, y también hacia los ángeles (músicos) que me apoyaron con calidez e hicieron swing conmigo.
        </p>

        <h2>"Angels Swing" significa…</h2>
        <p>
          Angels Swing comenzó en 1996, cuando me paré frente a mi sueño. Antes de convertirse en "Angels Swing," era un proyecto completamente solitario. Si le quitas la "s" a "Swing," se convierte en "Angel's Wing" (el ala del ángel). Si le quitas la "w" a "Swing," se convierte en "Angel's Sing" (el canto del ángel).
        </p>
        <p>
          Pero con los años, al conocer a "Ángeles" legendarios como Leonard Gaskin, Grady Tate y Bob Cranshaw, el proyecto evolucionó hacia "Angels Swing" — es decir, ángeles en plural, haciendo swing juntos.
        </p>
        <p>
          Estos ángeles ya han fallecido y están en el cielo. Y aun así, siento que siguen haciendo swing aquí mismo, conmigo.
        </p>
      </div>
    </section>

    <SubGrid cards={subCards} columns={3} />
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap {
    padding-top: 1.5rem;
    padding-bottom: 0.5rem;
  }

  .essay {
    padding: 2rem 1.5rem 4rem;
  }
  .essay-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .essay-inner h2 {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 26px;
    color: var(--color-accent);
    margin: 2.5rem 0 1rem;
  }
  .essay-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.2rem;
  }
  .essay-inner em { font-style: italic; }

  @media (max-width: 720px) {
    .essay-inner h2 { font-size: 22px; }
  }
</style>
