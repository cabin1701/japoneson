---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FeaturedProject from '../../components/FeaturedProject.astro';
import ProjectsGrid from '../../components/ProjectsGrid.astro';
---

<Layout title='Shoko "Seina" Shiraishi' lang="es">
  <Header lang="es" />
  <main>
    <Hero lang="es" />
    <SectionHeader title="Proyectos" />
    <FeaturedProject lang="es" />
    <SectionHeader
      title="The Mystery Entertainment"
      variant="mystery"
      subtitle={'"Los puntos se conectarán aquí, en KANMON."'}
      showTorii={true}
      toriiHref="/es/mystery/"
      loadingText="Cargando el misterio..."
    />
    <ProjectsGrid lang="es" />
  </main>
  <Footer lang="es" />
</Layout>
