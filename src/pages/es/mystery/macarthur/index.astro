---
import Layout from '../../../../layouts/Layout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

interface KCard {
  title: string;
  image: string;
  alt: string;
  desc: string;
  href: string;
}

const koreanWar: KCard[] = [
  {
    title: 'La Sombra de Kokura — Los Soldados Negros',
    image: IMG('2026/04/blacksoldiers-600x573.jpg'),
    alt: 'Los Soldados Negros',
    desc: 'Una oración silenciosa por los soldados que cruzaron el Estrecho de Kanmon y nunca volvieron a casa.',
    href: `${base}es/mystery/macarthur/korea-black-soldiers/`,
  },
  {
    title: 'La 24.ª División de Infantería',
    image: IMG('2026/04/TL-WINTER-13-D-1-600x600.jpg'),
    alt: 'La 24.ª División de Infantería',
    desc: 'Por los muchachos que dejaron Kyushu y nunca miraron atrás — esta es una oración por lo que llevaron consigo.',
    href: `${base}es/mystery/macarthur/korea-24th/`,
  },
  {
    title: 'David Valley',
    image: IMG('2026/04/IMG_2028-02-600x601.jpg'),
    alt: 'David Valley',
    desc: 'El último guardián de una era que se desvanece — quien pasó el testigo invisible a un espíritu libre llegado de Japón.',
    href: `${base}es/mystery/macarthur/david-valley/`,
  },
  {
    title: 'Monica Lewis',
    image: IMG('2026/04/korea1.jpg'),
    alt: 'Monica Lewis',
    desc: 'En 1951, mi amiga la Sra. Monica Lewis (1922-2015) entretuvo "para los muchachos" que sirvieron en la Guerra de Corea junto a Danny Kaye.',
    href: `${base}es/swing/for-the-boys/`,
  },
];

const trail = [
  { slug: 'mystery', title: 'THE MYSTERY ENTERTAINMENT', path: `${base}es/mystery/` },
  { slug: 'macarthur', title: "LA SOMBRA DEL GENERAL", path: `${base}es/mystery/macarthur/` },
];
---

<Layout title="La Sombra del General — Japonéson" lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      title="La Sombra del General"
      subtitle="El siglo XX"
      titleFont="var(--font-display-cinzel)"
      titleWeight={700}
      titleSize="60px"
      image={`${base}images/mystery/hero_macarthur.jpg`}
      align="center"
      height={1000}
      fit="cover"
      overlayTop={0}
      overlayBottom={0}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p class="dedication">
          Dedico este capítulo a mis queridos amigos: al
          <strong>Sr. David Valley</strong>, el último Director Ejecutivo de la
          Asociación de la Guardia de Honor MacArthur, quien me adoptó como su
          "Hija del Ejército" y me confió las verdades no contadas de la
          historia, y al <strong>Sr. Donald Versaw</strong>, quien fue
          capturado en Filipinas después de que el General se viera forzado a
          dejarlos atrás.
        </p>

        <hr class="navy-rule" />

        <h2 class="section-q">¿Por qué MacArthur?<br />¿Por qué aquí, en el Estrecho de Kanmon?</h2>
        <p class="sub-q">Y, ¿por qué alguien como yo</p>
        <p class="sub-q">— viviendo fuera de los límites de la sociedad — tenía que ser quien contara esta historia?</p>
        <p class="lead-quote">
          Todo comenzó con un 'problema de proyección' en el Memorial
          MacArthur de Norfolk. Un documental que no llegó a reproducirse.
          Las historias no contadas de los MUCHACHOS. Para mí, se siente como
          una carta del General, a la deriva a través del tiempo y el
          espacio, hasta llegar a esta orilla, en el Estrecho de Kanmon."
        </p>

        <hr class="navy-rule" />

        <p>
          A finales de 2012, creé un folleto titulado
          <strong>"Kitakyushu: Tiempos de guerra y posguerra — Los recordamos."</strong>
          Lo distribuí en febrero de 2023 en un evento que celebraba el
          50.º aniversario de la ciudad de Kitakyushu. Mi motivación era
          simple: aunque la tecnología moderna y la economía de Kitakyushu
          se construyeron sobre una base de historia militar desde la era
          Meiji, esa historia rara vez se comenta.
        </p>

        <p>
          Mientras investigaba la "Memorial Cross" — un monumento de la
          Guerra de Corea en Kokura — descubrí que la 24.ª División de
          Infantería había estado destacada allí. Cuando contacté a su
          asociación de veteranos, me presentaron al
          <strong>Sr. David Valley</strong>, quien expresó un fuerte deseo de
          conectar conmigo.
        </p>

        <p>
          Por esa misma época, supe que se celebraba una convención de la
          <strong>American Defenders of Bataan and Corregidor Memorial Society</strong>
          (ADBCMS), a la que pertenecía mi amigo el
          <strong>Sr. Donald Versaw</strong>, en Norfolk, Virginia — ciudad
          hermana de Kitakyushu. Sintiendo una atracción misteriosa, viajé a
          Norfolk en mayo como representante de Donald (quien no pudo
          asistir) y fui invitada a cantar en la convención.
        </p>

        <p>
          Cuando le conté esto a David, insistió:
          <em>"El Memorial MacArthur está en Norfolk. Los contactaré yo mismo; tienes que visitarlo."</em>
        </p>

        <p>
          Este viaje me llevó a Nueva York (mi segundo hogar), Norfolk para
          la convención, San Diego para visitar a David Valley, y Los
          Ángeles para ver a Monica Lewis. Mirando atrás, siento como si el
          propio <strong>General</strong> me hubiera estado guiando.
        </p>

        <p>
          Mi partida comenzó en el Aeropuerto de Fukuoka — ubicado en el
          antiguo emplazamiento de la Base Aérea de Itazuke, desde donde la
          <strong>Smith Force</strong> se desplegó por primera vez hacia
          Corea. Mi primera parada fue Hawái, donde visité el
          <strong>USS Missouri</strong>, el acorazado donde Japón firmó los
          documentos de rendición.
        </p>

        <p>
          En Nueva York, me hospedé con mi amigo <strong>Bob Cranshaw</strong>,
          un legendario contrabajista de jazz y veterano que sirvió en la
          Guerra de Corea como soldado negro. Fue miembro fundador de la
          banda de <em>Saturday Night Live</em> y tocó junto a gigantes como
          Sonny Rollins durante décadas.
          <strong>Una vez me contó una historia en el andén del metro de Tokio</strong> —
          sobre el día en que su amigo John Belushi no se presentó porque
          había fallecido, y cómo esa tragedia llevó a Bob a alejarse de las
          drogas para siempre. Durante mi estancia en Nueva York, otro viejo
          amigo me invitó a ver el <strong>USS Intrepid</strong>. En ese
          momento no sabía nada de este portaaviones, pero después descubrí
          que desempeñó un papel vital en la segunda campaña del General en
          Filipinas.
        </p>

        <p>
          El momento más impactante ocurrió en Norfolk. El Memorial
          MacArthur organizó la proyección de un documental sobre
          prisioneros de guerra, creado por veteranos y sus familias.
          Mientras estábamos sentados en la sala, un fallo técnico detuvo
          repentinamente la película. La reacción de los ex prisioneros de
          guerra y sus familias fue intensa — una ira abrumadora y visceral.
          Fue entonces cuando comprendí de verdad: estos eran los hombres
          abandonados en Filipinas cuando MacArthur hizo su famosa huida,
          prometiendo <em>"Volveré."</em> Ellos fueron los que se
          convirtieron en prisioneros de Japón.
        </p>

        <p>
          Esos mismos prisioneros fueron finalmente trasladados en barco al
          puerto de <strong>Moji</strong>.
        </p>

        <p>
          Además, cuando estalló la Guerra de Corea, la 24.ª División de
          Infantería — la más cercana a Corea — fue la primera enviada al
          frente bajo el mando de MacArthur.
        </p>

        <p>
          En Kokura existe una historia oscura y silenciada conocida como el
          <strong>"Motín de Kokura"</strong> (el modelo para
          <em>'Kuroji no E'</em> de Seicho Matsumoto). Soldados
          afroamericanos, llegados en tren desde Gifu, fueron llevados al
          límite por la combinación de la discriminación racial y el terror
          de ser enviados a una "tierra de muerte." El 12 de julio de 1950,
          bajo las órdenes de MacArthur, fueron embarcados en improvisados
          botes pesqueros y carboneros en el puerto de Moji y enviados a
          través del mar hacia Busan, desapareciendo en las brutales
          batallas de la "Guerra Olvidada."
        </p>

        <p>
          En este capítulo, presento estas tres historias olvidadas de la
          Guerra de Corea y te invito a caminar conmigo a través de mi
          viaje — y mi blog — mientras descubrimos juntos la verdad.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <section class="war-block">
      <h2 class="war-title">La Guerra de Corea</h2>
      <div class="kw-grid">
        {koreanWar.map((c) => (
          <a class="kw-card" href={c.href}>
            <div class="kw-image"><img src={c.image} alt={c.alt} loading="lazy" /></div>
            <h3 class="kw-cardtitle">{c.title}</h3>
            <p class="kw-desc">{c.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <hr class="section-divider" />

    <section class="war-block">
      <h2 class="war-title">La Guerra del Pacífico</h2>
      <div class="pw-grid">
        <a class="pw-card" href={`${base}es/mystery/macarthur/donald-versaw/`}>
          <div class="pw-image"><img src={IMG('2026/04/don-young-1.jpg')} alt="Donald Versaw" loading="lazy" /></div>
          <h3 class="pw-cardtitle">Correos de un viejo G.I. — Donald Versaw</h3>
          <p class="pw-desc">En 1999, conocí a un ex prisionero de guerra que había sido capturado en Filipinas.</p>
        </a>
        <a class="pw-card" href="https://en.japoneson.com/swing/remember/moji#pow">
          <div class="pw-image"><img src={IMG('2026/06/ac40077afcfee4ce63b0bbc49b90b460-scaled-1-1-1-600x600.jpg')} alt="Prisioneros de Guerra del Pacífico" loading="lazy" /></div>
          <h3 class="pw-cardtitle">Prisioneros de Guerra del Pacífico</h3>
          <p class="pw-desc">Kanmon fue la puerta de entrada de los prisioneros aliados provenientes de los frentes del sur.</p>
        </a>
        <div class="pw-card pw-card-static">
          <div class="pw-image"><img src={IMG('2026/04/IMG_1927-e1776990033305-768x765.jpg')} alt="SEINA — Vocalista, Amiga de los Prisioneros de Guerra — Sociedad Memorial ADBC #78" loading="lazy" /></div>
        </div>
      </div>
    </section>

    <section class="memorials">
      <h2 class="war-title">Memoriales</h2>
      <p class="mem-tagline"><strong>Puedes decirles: "Te recuerdo"</strong></p>

      <article class="mem-item">
        <figure class="mem-image">
          <img src={IMG('2026/06/121226W9Q9761_1500-1-683x1024.jpg')} alt="Kokura Memorial Cross" loading="lazy" />
        </figure>
        <div class="mem-body">
          <h3 class="mem-title">Kokura Memorial Cross</h3>
          <p>
            Después de la Guerra del Pacífico, la 24.ª División de
            Infantería, comandada por el
            <a href="https://en.wikipedia.org/wiki/William_F._Dean" target="_blank" rel="noopener">Mayor General William F. Dean</a>,
            estuvo destacada en Kokura. Debido a la proximidad de Kokura a
            Corea del Sur, esta división fue una de las primeras enviadas a
            la Guerra de Corea
            (<a href="https://tour.crystallize.jp/archives/937#21st" target="_blank" rel="noopener">el primer regimiento enviado</a>).
            La división sufrió 3.602 muertos y heridos, y 2.962 capturados,
            incluyendo a su comandante, el Mayor General Dean.
          </p>
          <p>
            Las fuerzas norcoreanas resultaron extremadamente duras, y las
            fuerzas de la ONU enfrentaron desafíos considerables. Los
            soldados caídos que eran enterrados temporalmente en Corea del
            Sur a menudo tenían que ser exhumados cuando la situación
            cambiaba. En consecuencia, Kokura fue elegida como el lugar
            para trasladar a estas víctimas para su procesamiento y
            repatriación. Esto provocó que un gran número de bajas pasara
            por Kokura, lo que impulsó la construcción del Memorial de la
            Guerra de Corea, la "Memorial Cross," en 1951.
          </p>

          <h4 class="mem-sub">Enlaces</h4>
          <ul class="mem-links">
            <li><a href="https://armyhistory.org/8204th-army-unit-american-graves-registration-service-group/" target="_blank" rel="noopener">"8204th Army Unit" (American Graves Registration Service Group)</a> / Army Historical Foundation</li>
            <li><a href="https://quartermasterfoundation.org/graves-registration-in-the-korean-conflict/" target="_blank" rel="noopener">"Graves Registration in the Korean Conflict"</a> / Army QuarterMaster Foundation</li>
            <li><a href="https://24thida.com/" target="_blank" rel="noopener">The 24th Infantry Division Association</a></li>
          </ul>

          <h4 class="mem-sub">Información de acceso</h4>
          <p>
            Se recomienda tomar un taxi. Pide al conductor que espere
            mientras visitas el lugar. No podrás conseguir un taxi en el
            sitio.
          </p>
          <p>
            Desde la Estación de Kokura: unos 4 km (2,5 millas)<br />
            Desde el Castillo de Kokura: unos 4,8 km (3 millas)<br />
            Por favor, muestra esto al taxista:
          </p>
          <figure class="mem-aux">
            <img src="https://tour.crystallize.jp/wp-content/uploads/2025/12/スクリーンショット-2025-12-02-7.30.33.png" alt="Taxi direction screenshot" loading="lazy" />
          </figure>
        </div>
      </article>

      <article class="mem-item mem-item-reverse">
        <figure class="mem-image">
          <img src={IMG('2026/06/img_9925-2-860x1024.jpg')} alt="Quarantine station" loading="lazy" />
        </figure>
        <div class="mem-body">
          <h3 class="mem-title">Los restos de la estación de cuarentena para prisioneros de guerra aliados</h3>
          <p>
            A finales de noviembre de 1945, llegaron simultáneamente cuatro
            "barcos infernales." Aproximadamente 60 pacientes con
            enfermedades infecciosas, incluida la disentería, fueron
            ubicados en el pabellón de aislamiento de la Estación de
            Cuarentena de Shimonoseki, en Enoura-cho, Hikoshima, ciudad de
            Shimonoseki, frente a Moji. Esta instalación funcionó como una
            sucursal del campo de Moji, aunque su período de operación no
            está claro. Los residentes recuerdan que los prisioneros de
            guerra, tras un período de relativa calma, fueron trasladados a
            un segundo campo cerca de Hikoshima Enoura-cho 2-chome, pero no
            se conocen más detalles.
          </p>

          <h4 class="mem-sub">Información de acceso</h4>
          <p>
            Toma <a href="https://www.kanmon-kisen.co.jp/es/route/ganryujima.html" target="_blank" rel="noopener">el Ferry de Ganryujima</a>
            desde el Muelle Karato en Shimonoseki o Marine Gate Moji en
            Mojiko. Una vez en la isla, camina hasta su punta para ver los
            restos de la antigua estación de cuarentena de prisioneros de
            guerra en Hikoshima (Shimonoseki), ubicada junto al Astillero
            Mitsubishi.
          </p>
          <p>
            Ganryujima es una pequeña isla en el Estrecho de Kanmon. En
            1612, fue el escenario de un famoso duelo entre Miyamoto Musashi
            y Sasaki Kojiro, conocido como la Batalla de Ganryu-jima, uno de
            los duelos de samuráis más célebres.
          </p>
        </div>
      </article>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
