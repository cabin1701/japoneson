  .mem-aux {
    margin: 1rem 0 0;
    max-width: 360px;
  }
  .mem-aux img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid rgba(0,0,0,0.1);
  }

  @media (max-width: 900px) {
    .kw-grid { grid-template-columns: repeat(2, 1fr); }
    .pw-grid { grid-template-columns: 1fr; }
    .mem-item,
    .mem-item.mem-item-reverse {
