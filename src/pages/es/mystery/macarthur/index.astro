  }
  .mem-body a { color: var(--color-accent); text-decoration: none; border-bottom: 1px solid currentColor; }
  .mem-body a:hover { color: var(--color-navy); }
  .mem-title {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 22px;
    color: var(--color-accent);
    margin: 0 0 1.2rem;
    letter-spacing: 0.02em;
  }
  .mem-sub {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 17px;
