  .intro-inner strong { font-weight: 400; color: var(--color-navy); }
  .intro-inner a { color: var(--color-accent); text-decoration: none; border-bottom: 1px solid currentColor; }
  .intro-inner a:hover { color: var(--color-navy); }

  .war-block {
    padding: 3rem 1.5rem 2rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .war-title {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 30px;
    color: var(--color-accent);
