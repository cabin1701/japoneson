    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem 2.5rem;
  }
  .kw-card {
    display: block;
    text-decoration: none;
    color: inherit;
    text-align: center;
    transition: transform 0.25s ease;
  }
  .kw-card:hover { transform: translateY(-2px); }
  .kw-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    margin: 0 auto 1rem;
    max-width: 240px;
  }
  .kw-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.25s ease;
  }
  .kw-card:hover .kw-image img { filter: brightness(1.05); }
  .kw-cardtitle {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-navy);
    margin: 0 0 0.6rem;
    line-height: 1.3;
    letter-spacing: 0.02em;
  }
  .kw-desc {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #444;
    margin: 0;
  }

  .pw-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 2.5rem;
  }
  .pw-card.pw-card-static { cursor: default; }
  .pw-card.pw-card-static:hover { transform: none; }
  .pw-card.pw-card-static:hover .pw-image img { filter: none; }
  .pw-card {
    display: block;
    text-decoration: none;
    color: inherit;
    text-align: center;
    transition: transform 0.25s ease;
  }
  .pw-card:hover { transform: translateY(-2px); }
  .pw-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    margin: 0 auto 1rem;
    max-width: 240px;
  }
  .pw-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pw-cardtitle {
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 19px;
    color: var(--color-navy);
    margin: 0 0 0.6rem;
    line-height: 1.3;
    letter-spacing: 0.02em;
  }
  .pw-desc {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #444;
    margin: 0;
  }
  hr.section-divider {
    border: none;
    border-top: 6px solid #8a8b6a;
    max-width: 1280px;
    margin: 1rem auto;
    opacity: 0.7;
  }

  .memorials {
    padding: 3rem 1.5rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
  }
  .mem-tagline {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: 600;
    font-size: 19px;
    color: var(--color-navy);
    text-align: center;
    margin: 0 0 3rem;
  }

