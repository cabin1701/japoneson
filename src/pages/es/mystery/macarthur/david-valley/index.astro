---
import Layout from '../../../../../layouts/Layout.astro';
import Header from '../../../../../components/Header.astro';
import Footer from '../../../../../components/Footer.astro';
import Breadcrumb from '../../../../../components/Breadcrumb.astro';
import ProjectHero from '../../../../../components/ProjectHero.astro';

const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

interface Row {
  year: string;
  heading: string;
  body: string;
}

const rows: Row[] = [
  {
    year: '1950 – Principios de 1951',
    heading: 'Desde los campos de batalla helados',
    body: "Como miembro de la 24.ª División de Infantería del Ejército de EE. UU., David fue enviado al frente de la brutal Guerra de Corea. Al sobrevivir a condiciones extremas y a la pérdida de muchos compañeros, cargó con la profunda sensación de haber sido “perdonado” por una razón.",
  },
  {
    year: 'Abril de 1951',
    heading: 'Uniéndose al General MacArthur',
    body: "Regresó a Japón escoltando al General tras su relevo del mando. En un giro dramático desde el infierno del campo de batalla, asumió el prestigioso papel de Guardia de Honor en Tokio. Estuvo junto al General en un momento decisivo, mientras los engranajes de la historia giraban.",
  },
  {
    year: 'Abril de 1951 – Marzo de 1952',
    heading: 'Un profundo amor por Japón',
    body: 'Incluso después de que el General partiera hacia Estados Unidos, David permaneció en Japón para completar su servicio. Durante este tiempo, fue testigo de la fortaleza y la amabilidad del pueblo japonés mientras reconstruía su nación. Este año en Japón se convirtió en un silencioso preludio de su encuentro con Seina décadas después.',
  },
  {
    year: 'Años 2000 – 2013',
    heading: 'El guardián de recuerdos que se desvanecen',
    body: 'A medida que sus compañeros de guardia fallecían uno a uno, David dio un paso al frente como líder. Como Director Ejecutivo y último Presidente de la Asociación de la Guardia de Honor del General MacArthur (GMHGA), dedicó su vida a preservar los registros históricos y el legado de sus compañeros.',
  },
  {
    year: 'Diciembre de 2012',
    heading: 'Un correo a través del océano',
    body: 'Llegó un mensaje de Seina, quien investigaba la Memorial Cross (el monumento de la 24.ª División) en Kokura. David se conmovió profundamente por la pasión de esta mujer japonesa que buscaba descubrir las “raíces” de su propio pasado.',
  },
  {
    year: '12 de mayo de 2013',
    heading: '"Las sombras se alargan"',
    body: "Citando las célebres palabras de MacArthur —“Las sombras se alargan para mí”—, David escribió su última carta a los miembros, anunciando el cierre de la Asociación. Habiendo cumplido su deber como último Presidente, quedó como un veterano solitario, listo para el próximo capítulo.",
  },
  {
    year: 'Finales de mayo de 2013',
    heading: 'El encuentro en San Diego',
    body: 'Solo semanas después de cerrar la Asociación, el Día de los Caídos, David finalmente conoció a Seina en San Diego. Al ver en sus ojos la misma “alma buscadora de la verdad” que él y sus compañeros una vez compartieron, la llamó cariñosamente “Maverick” (espíritu libre) y le confió el testigo invisible de la historia.',
  },
];

const trail = [
  { slug: 'mystery', title: 'THE MYSTERY ENTERTAINMENT', path: `${base}es/mystery/` },
  { slug: 'macarthur', title: "LA SOMBRA DEL GENERAL", path: `${base}es/mystery/macarthur/` },
  { slug: 'david-valley', title: 'DAVID VALLEY', path: `${base}es/mystery/macarthur/david-valley/` },
];
---

<Layout title="David Valley — Japonéson" lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      title="David Valley"
      subtitle="La Guardia de Honor de MacArthur"
      titleFont="var(--font-display-cinzel)"
      titleWeight={600}
      titleSize="60px"
      titleColor="#acbdc9"
      image={`${base}images/mystery/hero_david-valley.jpg`}
      align="center"
      height={860}
      fit="cover"
      overlayTop={0}
      overlayBottom={0}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p>
          Mi encuentro con David Valley comenzó cuando investigaba la
          "Memorial Cross" en Kokura, Kitakyushu. Fui a la oficina del
          distrito local, pero no pude encontrar una respuesta convincente
          sobre por qué había allí un monumento de la Guerra de Corea.
          Incluso las historias de la gente local no me parecían correctas.
          Así que empecé a visitar librerías de viejo, buscando recuerdos de
          Kokura durante la Ocupación.
        </p>

        <p>
          Allí encontré un libro viejo y frágil que parecía que se
          desmoronaría en cualquier momento. Contenía registros de la
          24.ª División de Infantería del Ejército de EE. UU. destacada en
          Kokura y de su comandante, el General Dean, profundamente querido
          por los ciudadanos locales. Pensé: "La 24.ª División de
          Infantería... quizás su asociación de veteranos pueda decirme
          algo."
        </p>

        <p>
          Con ese simple pensamiento, envié un correo electrónico. Ese fue
          el momento en que los engranajes del destino comenzaron a girar.
          Recibí una respuesta inmediata de Tom Seal, el webmaster, seguida
          poco después por un mensaje en el formulario de contacto de mi
          sitio web de David Valley. Dijo que era un "Guardia de Honor" del
          General MacArthur. En ese momento, ni siquiera sabía que existía
          tal organización.
        </p>

        <p class="across-eras">
          A través de épocas, edades, países y trasfondos, nos encontramos
          como si algo invisible nos guiara. No fue hasta 13 años después
          cuando comprendí que se me había confiado una "Llave de la
          Historia" que nadie en Japón conocía. Aquí presentaré a David — el
          hombre que guarda el corazón de este "Mystery Entertainment" — su
          trasfondo, y quién fue como figura clave en esta historia.
        </p>

        <hr class="olive-divider" />

        <div class="dv-table">
          <div class="dv-row dv-header">
            <div class="dv-year">Año</div>
            <div class="dv-events">Eventos</div>
          </div>
          {rows.map((r, i) => (
            <div class:list={['dv-row', i % 2 === 0 ? 'is-shade' : 'is-plain']}>
              <div class="dv-year"><strong>{r.year}</strong></div>
              <div class="dv-events">
                <p class="dv-heading"><strong>{r.heading}</strong></p>
                <p class="dv-body">{r.body}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="dv-photos">
          <figure><img src={IMG('2026/03/IMG_2041-600x450.jpg')} alt="Seina, la Sra. Valley y David Valley en San Diego, Día de los Caídos de 2013" loading="lazy" /></figure>
          <figure><img src={`${base}images/mystery/IMG_2050.jpg`} alt="Gorra de ADOPTED ARMY DAUGHTER firmada por David Valley" loading="lazy" /></figure>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 4rem;
  }
  .intro-inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .intro-inner p {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.3rem;
  }
  .intro-inner strong { font-weight: 700; color: #1a1a1a; }
  .intro-inner em { font-style: italic; }

  .intro-inner p.across-eras {
    font-family: 'Gabriela', serif;
    font-size: 19px;
    line-height: 1.75;
    color: var(--color-navy);
    font-style: italic;
    margin: 2rem 0;
  }

  .intro-inner hr.olive-divider {
    border: none;
    border-top: 6px solid #8a8b6a;
    margin: 2.5rem 0;
    opacity: 0.8;
  }

  .dv-table {
    width: 100%;
    margin: 2rem 0;
    border: 1px solid #c8c8c8;
  }
  .dv-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    border-bottom: 1px solid #c8c8c8;
  }
  .dv-row:last-child { border-bottom: none; }
  .dv-row.dv-header {
    background: transparent;
  }
  .dv-row.is-shade {
    background: rgba(33, 50, 101, 0.04);
  }
  .dv-year {
    padding: 1.2rem 1rem;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    color: #2a2a2a;
    border-right: 1px solid #c8c8c8;
  }
  .dv-events {
    padding: 1.2rem 1.2rem;
  }
  .dv-row.dv-header .dv-year,
  .dv-row.dv-header .dv-events {
    font-weight: 700;
    color: #1a1a1a;
  }
  .dv-heading {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 17px;
    color: #1a1a1a;
    margin: 0 0 0.6rem !important;
  }
  .dv-body {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: #2a2a2a;
    margin: 0 !important;
  }

  .dv-photos {
    margin: 2.5rem 0 0;
    display: grid;
    grid-template-columns: 63fr 37fr;
    gap: 2rem;
    align-items: start;
  }
  .dv-photos figure { margin: 0; }
  .dv-photos img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }
  @media (max-width: 700px) {
    .dv-photos { grid-template-columns: 1fr; }
  }

  @media (max-width: 700px) {
    .dv-row { grid-template-columns: 1fr; }
    .dv-year { border-right: none; border-bottom: 1px solid #c8c8c8; }
  }
</style>
