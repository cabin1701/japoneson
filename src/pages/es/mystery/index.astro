---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ProjectHero from '../../../components/ProjectHero.astro';
const base = import.meta.env.BASE_URL;
const IMG = (p: string) => `/images/wp/${p}`;

interface MysteryCard {
  title: string;
  century: string;
  image: string;
  alt: string;
  href: string;
  width: 'wide' | 'narrow';
  layout: 'image-top' | 'title-top';
}

const cards: MysteryCard[] = [
  {
    title: 'La Restauración Meiji',
    century: 'El siglo XIX',
    image: IMG('2026/02/IMG_0229-1-scaled-e1772128886839-1024x902.jpeg'),
    alt: 'La Restauración Meiji',
    href: `${base}es/mystery/meiji/`,
    width: 'wide',
    layout: 'title-top',
  },
  {
    title: 'La Sombra del General',
    century: 'El siglo XX',
    image: IMG('2026/03/IMG_2036-scaled-e1772714174506-1024x739.jpg'),
    alt: 'La Sombra del General',
    href: `${base}es/mystery/macarthur/`,
    width: 'narrow',
    layout: 'image-top',
  },
  {
    title: 'Susurros Antiguos',
    century: 'Tiempos antiguos',
    image: IMG('2026/02/IMG_9916-1024x768.jpeg'),
    alt: 'Susurros Antiguos',
    href: `${base}es/mystery/ancient/`,
    width: 'narrow',
    layout: 'image-top',
  },
  {
    title: 'La Historia de los Heike',
    century: 'El siglo XII',
    image: IMG('2026/02/IMG_0012-scaled-e1771766815902-1-e1772714196464-1024x751.jpeg'),
    alt: 'La Historia de los Heike',
    href: `${base}es/mystery/hieke/`,
    width: 'wide',
    layout: 'title-top',
  },
];

const trail = [
  { slug: 'mystery', title: 'THE MYSTERY ENTERTAINMENT', path: `${base}es/mystery/` },
];
---

<Layout title='The Mystery Entertainment — Japonéson' lang="es">
  <Header lang="es" />
  <main>
    <ProjectHero
      kicker="Los puntos se conectarán aquí, en KANMON."
      title="The Mystery Entertainment"
      subtitle="Cargando el misterio..."
      titleFont="var(--font-display-cinzel-dec)"
      titleWeight={600}
      titleSize="60px"
      image={`${base}images/mystery/hero_mystery.jpg`}
      align="center"
      height={1000}
      fit="cover"
      overlayTop={0}
      overlayBottom={0}
    />

    <div class="container breadcrumb-wrap">
      <Breadcrumb trail={trail} lang="es" />
    </div>

    <section class="intro">
      <div class="intro-inner">
        <p class="okazari">Un «juego de riesgo vital» jugado por Seina para despojar el «Okazari» y observar el verdadero plano (la realidad).</p>

        <p class="okazari okazari-vega">-Vegapedia-</p>

        <hr class="navy-rule" />
        <br>

        <p><strong>Marzo de 2022.</strong></p>

        <p>Me mudé a Shimonoseki, prefectura de Yamaguchi.</p>

        <p>
          En noviembre de 2021, me registré con antelación para que mis
          cenizas fueran esparcidas en el Santuario Mekari, con vista al
          Estrecho de Kanmon. Unos meses después, sintiendo un cambio global
          en la seguridad alimentaria, decidí buscar una base para la
          autosuficiencia.
        </p>

        <p>
          En Japón existe un creciente problema de "Akiya" (casas vacías).
          Debido a una población en declive y envejecimiento, muchas casas
          abandonadas se venden o alquilan a precios muy bajos. Buscando en
          varias prefecturas, encontré una casa muy antigua con jardín en
          Shimonoseki por solo 32.000 yenes (unos 200 dólares) al mes. En
          esta ciudad de colinas empinadas, muchas zonas son inaccesibles en
          coche, lo que hace que las propiedades pierdan valor de mercado.
        </p>

        <p>
          Esta casa está a 20 minutos a pie del Santuario Akama. Para mí,
          que llevaba mucho tiempo queriendo adentrarme en <em>El Cuento de
          Heike</em> antes del final de mi vida, era el lugar perfecto.
          También era una propiedad "apta para bricolaje" — es decir, tuve
          que reconstruirla yo misma solo para hacerla habitable.
        </p>

        <p class="begin"><strong>Aquí es donde comenzó la historia, el "Mystery Entertainment".</strong></p>

        <p>
          En Shimonoseki, comencé a tropezar con fragmentos de historia
          oculta — piezas de un rompecabezas que forman los cimientos del
          Japón moderno, pero de las que es difícil hablar oficialmente.
        </p>

        <h5 class="closing">Al final, la historia es el entretenimiento de misterio definitivo.</h5>
      </div>
    </section>

    <section class="mystery-grid-wrap">
      <div class="mystery-grid">
        {cards.map((c) => (
          <a class:list={['mystery-card', `is-${c.width}`, `is-${c.layout}`]} href={c.href}>
            {c.layout === 'title-top' && (
              <div class="mystery-text">
                <p class="mystery-century">{c.century}</p>
                <h3 class="mystery-title">{c.title}</h3>
              </div>
            )}
            <div class="mystery-image">
              <img src={c.image} alt={c.alt} loading="lazy" />
            </div>
            {c.layout === 'image-top' && (
              <div class="mystery-text">
                <p class="mystery-century">{c.century}</p>
                <h3 class="mystery-title">{c.title}</h3>
              </div>
            )}
          </a>
        ))}
      </div>
    </section>

    <section class="david-email">
      <div class="david-email-inner">
        <blockquote>
          <p>
            Seina: Me alegra saber de ti. Es admirable que quieras informar
            a la gente sobre los "desafortunados" años de guerra y la
            historia de los prisioneros de guerra. No es un tema que la
            mayoría de los japoneses quiera discutir, ya que refleja mal a
            la nación. Viví en Tokio unos años a principios de los 70 y
            cuatro años a finales de los 80. Me dedicaba a los negocios de
            alta tecnología y conocí a cientos y cientos de japoneses,
            aunque ninguno admitía haber estado en el ejército durante la
            Segunda Guerra Mundial, aunque tuvieran la edad apropiada. Las
            atrocidades cometidas por el ejército japonés antes y durante
            la Segunda Guerra Mundial son muchas y horribles. Ya sé
            demasiado sobre ellas y no me interesa discutirlas, salvo para
            decir que la postura oficial del gobierno japonés ha sido de
            total no reconocimiento. Por eso creo que podrías estar
            pisando aguas peligrosas. Creo que es mejor política, para
            gente como tú y yo, cerrar el libro al final de la Segunda
            Guerra Mundial y mirar las relaciones positivas que nuestros
            países han desarrollado desde entonces.
          </p>
          <p>
            No quiero ni espero que el pueblo japonés se muestre demasiado
            agradecido con nosotros, pero sí me inquieta cuando no
            reconocen la ayuda extraordinaria que Estados Unidos y algunos
            de nuestros aliados brindaron después de la Segunda Guerra
            Mundial. Me alegra mucho que una persona como tú tenga el
            interés suficiente para investigar por su cuenta. Buena
            suerte,<br>
            <a href={`${base}es/mystery/macarthur/david-valley/`}>David</a>
          </p>
        </blockquote>
      </div>
    </section>
  </main>
  <Footer lang="es" />
</Layout>

<style>
  .breadcrumb-wrap { padding-top: 1rem; padding-bottom: 0; }

  .intro {
    background: var(--color-bg);
    padding: 3rem 1.5rem 2rem;
  }
  .intro-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .intro-inner p {
    font-family: 'Gabriela', serif;
    font-size: 18px;
    line-height: 1.75;
    color: #2a2a2a;
    margin: 0 0 1.2rem;
  }
  .intro-inner em { font-style: italic; }
  .intro-inner strong { font-weight: 600; }

  .intro-inner p.okazari {
    text-align: center;
    font-family: 'Gabriela', serif;
    font-weight: 700;
    font-size: 21px;
    color: var(--color-navy);
    line-height: 1.55;
    margin: 0 0 0.3rem !important;
  }
  .intro-inner p.okazari-vega {
    margin: 1.6rem 0 2.5rem !important;
  }

  .begin {
    text-align: center;
    margin: 2.5rem 0 !important;
  }

  .intro-inner h5.closing {
    text-align: center;
    font-family: 'Gabriela', serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--color-accent);
    margin: 2rem 0 0;
    letter-spacing: 0.02em;
   
  }

  .mystery-grid-wrap {
    padding: 2rem 1.5rem 3rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .mystery-grid {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 3.5rem 3rem;
    align-items: start;
  }
  .mystery-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .mystery-card:hover { transform: translateY(-2px); }
  .mystery-card:hover .mystery-image img { filter: brightness(1.05); }

  .mystery-card.is-wide { grid-column: span 6; }
  .mystery-card.is-narrow { grid-column: span 4; }

  .mystery-image {
    width: 100%;
    overflow: hidden;
    border-radius: 2px;
  }
  .mystery-image img {
    display: block;
    width: 100%;
    height: auto;
    transition: filter 0.25s ease;
  }

  .mystery-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mystery-card.is-image-top .mystery-text { margin-top: 1rem; }
  .mystery-card.is-title-top .mystery-text { margin-bottom: 1rem; }

  .mystery-card.is-wide .mystery-text {
    align-items: flex-start;
    text-align: left;
  }
  .mystery-card.is-narrow .mystery-text {
    align-items: flex-end;
    text-align: right;
  }

  .mystery-century {
    margin: 0;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 15px;
    color: #666;
    font-style: italic;
  }
  .mystery-title {
    margin: 0;
    font-family: var(--font-display-cinzel);
    font-weight: 600;
    font-size: 26px;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  @media (max-width: 768px) {
    .mystery-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .mystery-card.is-wide,
    .mystery-card.is-narrow { grid-column: 1 / -1; }
    .mystery-card.is-narrow .mystery-text {
      align-items: flex-start;
      text-align: left;
    }
    .mystery-title { font-size: 22px; }
  }

  .david-email {
    padding: 3rem 1.5rem 4rem;
  }
  .david-email-inner {
    max-width: 850px;
    margin: 0 auto;
  }
  .david-email blockquote {
    border-left: 3px solid var(--color-rule);
    padding: 0.5rem 0 0.5rem 1.4rem;
    margin: 0;
    font-family: var(--font-italic-quote);
    font-style: italic;
    color: #444;
  }
  .david-email blockquote p {
    font-family: var(--font-italic-quote);
    font-style: italic;
    font-size: 21px;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .david-email blockquote a {
    font-style: normal;
    color: var(--color-navy);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .david-email blockquote a:hover { color: var(--color-accent); }

  @media (max-width: 720px) {
    .intro-inner p { font-size: 15.5px; }
    .closing { font-size: 17px; }
    .david-email blockquote p { font-size: 16px; }
  }
</style>
